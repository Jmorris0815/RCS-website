---
import { SEO } from 'astro-seo';
import { siteConfig } from '../config/site';
import Tracking from '../components/Tracking.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, image, canonical, noindex = false } = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/og-image.png', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#CF0515" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Tag Manager — same container as BaseLayout so this landing page
         shares the production conversion + analytics tag setup. -->
    <script is:inline define:vars={{ gtmId: siteConfig.googleTagManagerId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>

    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      openGraph={{
        basic: { title, type: 'website', image: ogImage, url: canonicalUrl },
        optional: { description, siteName: siteConfig.name, locale: 'en_US' },
      }}
      twitter={{ card: 'summary_large_image', title, description, image: ogImage }}
    />

    <Tracking />

    <slot name="head" />
  </head>
  <body class="bg-white text-ink-primary font-sans antialiased">
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.googleTagManagerId}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <header class="sticky top-0 z-40 bg-white border-b border-line">
      <div class="max-w-container mx-auto px-4 lg:px-8 h-16 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center shrink-0" aria-label="Right Choice Seamless Gutters — home">
          <img
            src="/logo-horizontal.png"
            alt="Right Choice Seamless Gutters"
            class="h-12 w-auto"
            width="171" height="96"
          />
        </a>
        <a
          href={`tel:${siteConfig.phoneRaw}`}
          data-call-location="landing_top_bar"
          class="inline-flex items-center gap-2 text-sm sm:text-base font-bold text-brand-primary hover:opacity-80 transition-opacity"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1A17 17 0 0 1 3 4c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
          </svg>
          {siteConfig.phoneDisplay}
        </a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-line bg-white">
      <div class="max-w-container mx-auto px-4 lg:px-8 py-8 text-sm text-ink-muted text-center">
        <p class="font-bold text-ink-primary mb-1">{siteConfig.name}</p>
        <p class="mb-2">
          <a href={`tel:${siteConfig.phoneRaw}`} data-call-location="landing_footer" class="hover:text-brand-primary">{siteConfig.phoneDisplay}</a>
          <span class="mx-1">·</span>
          <a href={`mailto:${siteConfig.email}`} class="hover:text-brand-primary">{siteConfig.email}</a>
        </p>
        <p class="text-xs">
          Serving Charlottesville · Albemarle · Greene · Madison · Fluvanna · VA Class A Licensed · BBB A+
        </p>
      </div>
    </footer>

    <slot name="end-of-body" />
  </body>
</html>
