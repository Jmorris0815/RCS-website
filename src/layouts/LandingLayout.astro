---
import { SEO } from 'astro-seo';
import { siteConfig } from '../config/site';
import Tracking from '../components/Tracking.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  /**
   * Optional one-line urgency strip rendered above the header. Default copy
   * is intentionally evergreen — true every month without manual updates.
   * Pass an empty string to suppress.
   */
  urgencyStrip?: string;
}

const {
  title,
  description,
  image,
  canonical,
  noindex = false,
  urgencyStrip = '⚡ This month\'s install slots fill in the order calls come in. Lock yours now.',
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/og-image.png', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#CF0515" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Tracking warmup: Google's edge resolves faster when we preconnect. -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.googleadservices.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <!-- Google Tag Manager — same container as BaseLayout. -->
    <script is:inline define:vars={{ gtmId: siteConfig.googleTagManagerId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>

    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      openGraph={{
        basic: { title, type: 'website', image: ogImage, url: canonicalUrl },
        optional: { description, siteName: siteConfig.name, locale: 'en_US' },
      }}
      twitter={{ card: 'summary_large_image', title, description, image: ogImage }}
    />

    <Tracking />

    <slot name="head" />
  </head>
  <body class="bg-white text-ink-primary font-sans antialiased">
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.googleTagManagerId}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    {urgencyStrip && (
      <div class="bg-brand-primary text-white text-center text-xs sm:text-sm font-semibold py-2 px-4">
        <span class="inline-flex items-center gap-2">
          {urgencyStrip}
        </span>
      </div>
    )}

    <header
      id="rcs-landing-header"
      data-shrunk="false"
      class="sticky top-0 z-40 bg-white border-b border-line transition-all duration-200"
    >
      <div class="max-w-container mx-auto px-4 lg:px-8 flex items-center justify-between gap-4 transition-all duration-200" data-header-inner>
        <a href="/" class="flex items-center shrink-0 transition-all duration-200" aria-label="Right Choice Seamless Gutters — home">
          <img
            src="/logo-horizontal.png"
            alt="Right Choice Seamless Gutters"
            data-header-logo
            class="h-20 lg:h-24 w-auto transition-all duration-200"
            width="171" height="96"
            fetchpriority="high"
          />
        </a>

        <div class="flex flex-col items-end gap-0.5">
          <a
            href={`tel:${siteConfig.phoneRaw}`}
            data-call-location="landing_top_bar"
            class="inline-flex items-center gap-2 text-base sm:text-lg font-bold text-brand-primary hover:opacity-80 transition-opacity"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1A17 17 0 0 1 3 4c0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
            </svg>
            {siteConfig.phoneDisplay}
          </a>
          <span class="text-[11px] text-ink-muted flex items-center gap-1.5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-success animate-pulse"></span>
            <span>Open · Mon–Sat 9–5</span>
          </span>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <slot name="end-of-body" />

    <script is:inline>
      // Tiny shrink-on-scroll for the landing header. Adds data-shrunk="true"
      // when scrolled past 80px so Tailwind/CSS can compress padding + logo.
      (function () {
        var hdr = document.getElementById('rcs-landing-header');
        if (!hdr) return;
        var scrolled = false;
        var onScroll = function () {
          var should = window.scrollY > 80;
          if (should !== scrolled) {
            scrolled = should;
            hdr.setAttribute('data-shrunk', should ? 'true' : 'false');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <style is:global>
      #rcs-landing-header[data-shrunk="true"] [data-header-inner] {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
      }
      #rcs-landing-header[data-shrunk="true"] [data-header-logo] {
        height: 3.5rem;
      }
      #rcs-landing-header[data-shrunk="false"] [data-header-inner] {
        padding-top: 1rem;
        padding-bottom: 1rem;
      }
    </style>
  </body>
</html>
