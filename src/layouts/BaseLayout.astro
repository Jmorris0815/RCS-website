---
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCTAs from '../components/StickyCTAs.astro';
import { siteConfig } from '../config/site';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  heroImage?: string; // optional preload hint for above-the-fold image
}

const {
  title,
  description,
  image,
  canonical,
  noindex = false,
  heroImage,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
// Default to /og-image.png (full Scott+Myriam logo + tagline) so every shared
// link gets a sane preview, not just pages that pass an explicit `image` prop.
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/og-image.png', Astro.site).toString();

// GHL chat widget (required for A2P 10DLC compliance), suppressed on pages
// that already collect a phone number so a customer doesn't see two competing
// "talk to us" surfaces in the same flow.
const chatWidgetExcludedPaths = ['/quote', '/contact'];
const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const showChatWidget = !chatWidgetExcludedPaths.some((p) => normalizedPath === p || normalizedPath.startsWith(p + '/'));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#CF0515" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {heroImage && (
      <link rel="preload" as="image" type="image/avif" href={heroImage.replace(/\.(jpg|jpeg|png)$/i, '.avif')} fetchpriority="high" />
    )}

    <!-- Google Tag Manager — same container as the legacy WordPress site so all
         existing conversion + analytics tags fire here without reconfiguration.
         GTM bootstraps gtag.js automatically; the phone_call_click dataLayer
         event below is the trigger for the Google Ads phone-conversion tag
         (configured inside the GTM dashboard). -->
    <script is:inline define:vars={{ gtmId: siteConfig.googleTagManagerId }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>

    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      openGraph={{
        basic: { title, type: 'website', image: ogImage, url: canonicalUrl },
        optional: { description, siteName: siteConfig.name, locale: 'en_US' },
      }}
      twitter={{ card: 'summary_large_image', title, description, image: ogImage }}
    />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="bg-white text-ink-primary font-sans antialiased">
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.googleTagManagerId}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:bg-brand-primary focus:text-white focus:px-4 focus:py-2 focus:rounded focus:z-[60]"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <StickyCTAs />
    <slot name="end-of-body" />

    <!--
      Tiny scroll-reveal + count-up runtime. ~30 lines, no library.
      Respects prefers-reduced-motion. Re-runs on Astro view-transition swaps.
    -->
    <script is:inline>
      function rcsInit() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Fade-up reveal
        const reveals = document.querySelectorAll('.reveal:not([data-revealed])');
        if (reduced) {
          reveals.forEach((el) => el.setAttribute('data-revealed', 'true'));
        } else if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.setAttribute('data-revealed', 'true');
                io.unobserve(e.target);
              }
            });
          }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
          reveals.forEach((el) => io.observe(el));
        } else {
          reveals.forEach((el) => el.setAttribute('data-revealed', 'true'));
        }

        // Count-up
        const counters = document.querySelectorAll('[data-count-to]:not([data-counted])');
        if (reduced) {
          counters.forEach((el) => {
            const to = el.getAttribute('data-count-to');
            el.textContent = el.dataset.format === 'comma'
              ? Number(to).toLocaleString('en-US')
              : to;
            el.setAttribute('data-counted', 'true');
          });
        } else if ('IntersectionObserver' in window) {
          const co = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              const el = e.target;
              const to = parseFloat(el.getAttribute('data-count-to'));
              const dur = parseInt(el.getAttribute('data-count-dur') || '1400', 10);
              const fmt = el.dataset.format === 'comma';
              const start = performance.now();
              function tick(now) {
                const t = Math.min((now - start) / dur, 1);
                const eased = 1 - Math.pow(1 - t, 3);
                const v = to * eased;
                el.textContent = fmt
                  ? Math.round(v).toLocaleString('en-US')
                  : (to % 1 ? v.toFixed(1) : Math.round(v).toString());
                if (t < 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
              el.setAttribute('data-counted', 'true');
              co.unobserve(el);
            });
          }, { threshold: 0.5 });
          counters.forEach((el) => co.observe(el));
        }

        // Sticky desktop CTA: show after hero (~600px scroll)
        const stickyDesk = document.querySelector('[data-sticky-cta]');
        if (stickyDesk) {
          const onScroll = () => {
            stickyDesk.setAttribute('data-show', window.scrollY > 600 ? 'true' : 'false');
          };
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }
      }

      // Phone-call conversion tracking. Delegated click listener bound once
      // on document; survives Astro view transitions. Pushes a `phone_call_click`
      // event to dataLayer (which GTM listens to) AND fires the same event via
      // gtag() if it's loaded directly. Scott configures the actual Google Ads
      // phone-conversion tag inside GTM with this event as the trigger.
      if (!window.__rcsPhoneTrackBound) {
        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest && e.target.closest('a[href^="tel:"]');
          if (!a) return;
          var num = a.getAttribute('href').replace(/^tel:/, '');
          var loc = a.getAttribute('data-call-location')
            || (a.closest('[data-call-context]') && a.closest('[data-call-context]').getAttribute('data-call-context'))
            || (a.closest('header') ? 'header' :
                a.closest('footer') ? 'footer' :
                a.closest('[data-sticky-cta]') ? 'sticky_desktop' :
                a.closest('.sticky-bar-mobile') ? 'sticky_mobile' :
                'inline');
          (window.dataLayer = window.dataLayer || []).push({
            event: 'phone_call_click',
            phone_number: num,
            call_location: loc,
            page_path: window.location.pathname,
          });
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'phone_call_click', {
              phone_number: num,
              call_location: loc,
              page_path: window.location.pathname,
            });
          }
        }, true);
        window.__rcsPhoneTrackBound = true;
      }

      document.addEventListener('astro:page-load', rcsInit);
    </script>

    {showChatWidget && (
      <script
        src="https://widgets.leadconnectorhq.com/loader.js"
        data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js"
        data-widget-id="69f0addcb001cc31bb5798ba"
        data-source="WEB_USER"
      ></script>
    )}
  </body>
</html>
