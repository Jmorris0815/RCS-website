---
import { siteConfig } from '../config/site';

export interface Props {
  eyebrow?: string;
  headline: string;
  subhead: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  trustChips?: string[];
  imageSrc?: string;
  imageAlt?: string;
}
const {
  eyebrow,
  headline,
  subhead,
  primaryCtaText = 'Get a Free Quote',
  primaryCtaHref = '/quote/',
  secondaryCtaText = `Call ${siteConfig.phoneDisplay}`,
  secondaryCtaHref = `tel:${siteConfig.phoneRaw}`,
  trustChips = ['Family-owned since 2014', 'Leaf Solution Authorized Dealer', 'Licensed & Insured'],
  imageSrc,
  imageAlt = '',
} = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-b from-brand-cream to-white">
  <div class="container-x py-[clamp(40px,5vw,72px)] grid lg:grid-cols-12 gap-10 items-center">
    <div class={imageSrc ? 'lg:col-span-5' : 'lg:col-span-12 max-w-3xl mx-auto text-center'}>
      {eyebrow && (
        <div class="text-brand-primary text-xs font-bold uppercase tracking-[0.18em] mb-4">
          {eyebrow}
        </div>
      )}
      <h1 class="text-fluid-4xl leading-[1.05] mb-5">{headline}</h1>
      <p class={`text-fluid-lg text-ink-muted mb-7 ${imageSrc ? 'max-w-xl' : 'max-w-2xl mx-auto'}`}>{subhead}</p>

      <div class={`flex flex-wrap gap-3 ${imageSrc ? '' : 'justify-center'}`}>
        <a href={primaryCtaHref} class="btn-primary">{primaryCtaText}</a>
        <a href={secondaryCtaHref} class="btn-secondary">{secondaryCtaText}</a>
      </div>

      {trustChips.length > 0 && (
        <ul class={`mt-8 flex flex-wrap gap-2 text-xs ${imageSrc ? '' : 'justify-center'}`}>
          {trustChips.map((chip) => (
            <li class="bg-white border border-line rounded-full px-3 py-1.5 font-medium text-ink-muted shadow-soft">
              {chip}
            </li>
          ))}
        </ul>
      )}
    </div>

    {imageSrc && (
      <div class="lg:col-span-7 relative">
        <div class="relative rounded-2xl overflow-hidden shadow-card ring-1 ring-line">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="w-full h-auto object-cover aspect-[4/3] lg:aspect-[3/2]"
            loading="eager"
            fetchpriority="high"
            width="1400"
            height="933"
          />
        </div>
        <div class="hidden lg:block absolute -bottom-5 -left-5 bg-brand-primary text-white px-5 py-3 rounded-lg shadow-card">
          <div class="text-2xl font-display font-bold leading-none">10+</div>
          <div class="text-[11px] uppercase tracking-wider opacity-90 mt-0.5">Years on Central VA roofs</div>
        </div>
      </div>
    )}
  </div>
</section>
