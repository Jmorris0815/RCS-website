---
import { siteConfig } from '../config/site';
---

<header class="sticky top-0 z-40 bg-white/92 backdrop-blur border-b border-line transition-shadow">
  <div class="max-w-container-wide mx-auto px-5 lg:px-8 min-h-24 lg:min-h-32 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center shrink-0" aria-label="Right Choice Seamless Gutters — home">
      <!-- Transparent-bg PNG so the header backdrop shows through (no white card). -->
      <img
        src="/logo-horizontal.png"
        alt="Right Choice Seamless Gutters"
        class="h-16 lg:h-24 w-auto"
        width="171" height="96"
      />
    </a>

    <!-- Desktop nav (lg+). Below lg the hamburger drawer carries these links. -->
    <nav class="hidden lg:flex items-center gap-4 xl:gap-7 text-[13px] xl:text-[14px] font-medium text-brand-charcoal" aria-label="Main">
      <a href="/services/" class="nav-link">Services</a>
      <a href="/products/" class="nav-link">Products</a>
      <a href="/locations/" class="nav-link">Service Area</a>
      <a href="/gallery/" class="nav-link">Gallery</a>
      <a href="/case-studies/" class="nav-link">Our Work</a>
      <a href="/reviews/" class="nav-link">Reviews</a>
      <a href="/blog/" class="nav-link">Blog</a>
      <a href="/about/" class="nav-link">About</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={`tel:${siteConfig.phoneRaw}`}
        class="hidden xl:inline-flex items-center gap-1.5 text-[14px] font-semibold text-brand-charcoal hover:text-brand-primary transition-colors"
      >
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        {siteConfig.phoneDisplay}
      </a>
      <a href="/quote/" class="inline-flex items-center btn-primary !py-2.5 !px-4 !text-[13px] !rounded-md">
        Get a Quote
      </a>
      <!-- Hamburger trigger — visible only below lg, where the desktop nav is hidden. -->
      <button
        type="button"
        id="rcs-menu-button"
        aria-expanded="false"
        aria-controls="rcs-mobile-menu"
        aria-label="Open navigation menu"
        class="lg:hidden -mr-1 p-2 rounded-md text-brand-charcoal hover:bg-brand-light hover:text-brand-primary transition-colors"
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!--
  Mobile navigation drawer. Outside the sticky <header> so it can take the full
  viewport without inheriting the header's stacking context. lg:hidden — desktop
  uses the inline nav above.
-->
<div
  id="rcs-mobile-menu"
  class="lg:hidden fixed inset-0 z-50 invisible opacity-0 transition-opacity duration-200 ease-out"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
>
  <div data-rcs-menu-backdrop class="absolute inset-0 bg-brand-charcoal/55"></div>
  <div
    id="rcs-mobile-menu-panel"
    class="absolute right-0 top-0 bottom-0 w-[88%] max-w-sm bg-white shadow-2xl flex flex-col translate-x-full transition-transform duration-200 ease-out"
  >
    <div class="flex items-center justify-between px-5 h-16 border-b border-line shrink-0">
      <span class="font-display text-lg font-semibold text-brand-charcoal">Menu</span>
      <button
        type="button"
        id="rcs-menu-close"
        aria-label="Close navigation menu"
        class="-mr-2 p-2 rounded-md text-brand-charcoal hover:bg-brand-light hover:text-brand-primary transition-colors"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto py-2" aria-label="Mobile navigation">
      <a href="/services/"     class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Services</a>
      <a href="/products/"     class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Products</a>
      <a href="/locations/"    class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Service Area</a>
      <a href="/gallery/"      class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Gallery</a>
      <a href="/case-studies/" class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Our Work</a>
      <a href="/reviews/"      class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Reviews</a>
      <a href="/blog/"         class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">Blog</a>
      <a href="/about/"        class="block px-5 py-3.5 text-[16px] font-medium text-brand-charcoal hover:bg-brand-light hover:text-brand-primary">About</a>
    </nav>

    <div class="px-5 py-4 border-t border-line space-y-3 shrink-0">
      <a
        href={`tel:${siteConfig.phoneRaw}`}
        class="flex items-center justify-center gap-2 w-full py-3 border-2 border-brand-primary text-brand-primary rounded-md font-semibold text-[15px] hover:bg-brand-primary hover:text-white transition-colors"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        {siteConfig.phoneDisplay}
      </a>
      <a href="/quote/" class="btn-primary w-full text-center !px-6">Get a Quote</a>
    </div>
  </div>
</div>

<script is:inline>
  // Mobile menu drawer: open/close, ESC, backdrop, body scroll lock, focus return.
  // Bind once per page; re-binds across Astro view-transitions via astro:page-load.
  function rcsMobileMenuInit() {
    var btn = document.getElementById('rcs-menu-button');
    var menu = document.getElementById('rcs-mobile-menu');
    if (!btn || !menu || btn.dataset.bound) return;
    btn.dataset.bound = 'true';
    var panel = document.getElementById('rcs-mobile-menu-panel');
    var closeBtn = document.getElementById('rcs-menu-close');
    var backdrop = menu.querySelector('[data-rcs-menu-backdrop]');

    function open() {
      menu.classList.remove('invisible');
      menu.classList.remove('opacity-0');
      panel.classList.remove('translate-x-full');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      // Send focus to the close button so keyboard/screen-reader users can dismiss.
      setTimeout(function () { try { closeBtn.focus(); } catch (_) {} }, 60);
    }
    function close() {
      menu.classList.add('opacity-0');
      panel.classList.add('translate-x-full');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      // Wait for the fade/slide transition before fully hiding (so it animates out).
      setTimeout(function () { menu.classList.add('invisible'); }, 220);
      try { btn.focus(); } catch (_) {}
    }

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !menu.classList.contains('invisible')) close();
    });
    // Close after any in-drawer link tap so the next page transition feels responsive.
    menu.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', close); });
  }
  document.addEventListener('astro:page-load', rcsMobileMenuInit);
</script>

<style>
  .nav-link {
    position: relative;
    padding-block: 4px;
    transition: color 200ms ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    bottom: -2px;
    height: 2px;
    background: theme('colors.brand.primary');
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover { color: theme('colors.brand.primary'); }
  .nav-link:hover::after { transform: scaleX(1); }
</style>
