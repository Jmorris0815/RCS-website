---
// Vanilla lightbox: any element with [data-lightbox-src] opens an overlay
// with the full image. ~25 lines of JS, zero deps. Esc / click-outside / × to close.
//
// IMPORTANT: initial state uses the Tailwind `hidden` utility (display: none)
// rather than the HTML `hidden` attribute, because `flex` would otherwise
// win specificity and the overlay would be visible on page load.
---

<div
  id="rcs-lightbox"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Photo viewer"
  class="hidden fixed inset-0 z-[80] bg-black/90 backdrop-blur-sm items-center justify-center p-4 cursor-zoom-out">
  <button type="button" data-lb-close aria-label="Close"
    class="absolute top-4 right-4 text-white text-3xl leading-none w-12 h-12 rounded-full hover:bg-white/10 transition-colors flex items-center justify-center">×</button>
  <img id="rcs-lightbox-img" alt="" class="max-w-full max-h-full object-contain rounded-lg" />
</div>

<script is:inline>
  function rcsLightboxInit() {
    const lb = document.getElementById('rcs-lightbox');
    const img = document.getElementById('rcs-lightbox-img');
    if (!lb || !img) return;

    function open(src, alt) {
      img.src = src;
      img.alt = alt || '';
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.remove('flex');
      lb.classList.add('hidden');
      lb.setAttribute('aria-hidden', 'true');
      img.src = '';
      img.alt = '';
      document.body.style.overflow = '';
    }

    const triggers = document.querySelectorAll('[data-lightbox-src]:not([data-lb-bound])');
    triggers.forEach((t) => {
      t.setAttribute('data-lb-bound', 'true');
      t.style.cursor = 'zoom-in';
      t.addEventListener('click', (e) => {
        e.preventDefault();
        open(t.getAttribute('data-lightbox-src'), t.getAttribute('data-lightbox-alt') || '');
      });
    });

    if (!lb.dataset.bound) {
      lb.addEventListener('click', (e) => {
        if (e.target === lb || e.target.matches('[data-lb-close]')) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !lb.classList.contains('hidden')) close();
      });
      lb.dataset.bound = 'true';
    }
  }
  document.addEventListener('astro:page-load', rcsLightboxInit);
</script>
