---
// Vanilla lightbox: any element with [data-lightbox-src] opens an overlay
// with the full image. ~25 lines of JS, zero deps. Esc / click-outside / × to close.
---

<div id="rcs-lightbox" hidden role="dialog" aria-modal="true" aria-label="Photo viewer"
  class="fixed inset-0 z-[80] bg-black/90 backdrop-blur-sm flex items-center justify-center p-4 cursor-zoom-out">
  <button type="button" data-lb-close aria-label="Close"
    class="absolute top-4 right-4 text-white text-3xl leading-none w-12 h-12 rounded-full hover:bg-white/10 transition-colors flex items-center justify-center">×</button>
  <img id="rcs-lightbox-img" alt="" class="max-w-full max-h-full object-contain rounded-lg" />
</div>

<script is:inline>
  function rcsLightboxInit() {
    const lb = document.getElementById('rcs-lightbox');
    const img = document.getElementById('rcs-lightbox-img');
    if (!lb || !img) return;
    const triggers = document.querySelectorAll('[data-lightbox-src]:not([data-lb-bound])');
    triggers.forEach((t) => {
      t.setAttribute('data-lb-bound', 'true');
      t.style.cursor = 'zoom-in';
      t.addEventListener('click', (e) => {
        e.preventDefault();
        const src = t.getAttribute('data-lightbox-src');
        const alt = t.getAttribute('data-lightbox-alt') || '';
        img.src = src; img.alt = alt;
        lb.hidden = false;
        document.body.style.overflow = 'hidden';
      });
    });
    function close() { lb.hidden = true; img.src = ''; document.body.style.overflow = ''; }
    if (!lb.dataset.bound) {
      lb.addEventListener('click', (e) => { if (e.target === lb || e.target.matches('[data-lb-close]')) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lb.hidden) close(); });
      lb.dataset.bound = 'true';
    }
  }
  document.addEventListener('astro:page-load', rcsLightboxInit);
</script>
