---
import { siteConfig } from '../../config/site';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'RoofingContractor',
  '@id': `${siteConfig.url}/#business`,
  name: siteConfig.name,
  alternateName: siteConfig.shortName,
  url: siteConfig.url,
  telephone: siteConfig.phoneDisplay,
  email: siteConfig.email,
  foundingDate: String(siteConfig.foundingYear),
  description:
    "Family-owned seamless gutter installer serving 9 Central Virginia counties. " +
    "Authorized Leaf Solution dealer specializing in Xtreme, New Wave, and Evelyn's " +
    "Leaf Solution gutter guards. .032 aluminum, hidden hangers standard.",
  image: `${siteConfig.url}/images/jobs/truck-jobsite-barn.jpg`,
  logo: `${siteConfig.url}/logo-mark.svg`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.city,
    addressRegion: siteConfig.address.state,
    postalCode: siteConfig.address.zip,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: siteConfig.serviceCenterCoords.lat,
    longitude: siteConfig.serviceCenterCoords.lng,
  },
  areaServed: [
    'Barboursville, VA',
    'Charlottesville, VA',
    'Orange, VA',
    'Madison, VA',
    'Greene County, VA',
    'Fluvanna County, VA',
    'Louisa County, VA',
    'Albemarle County, VA',
    'Culpeper, VA',
    'Culpeper County, VA',
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '12:00',
    },
  ],
  priceRange: '$$',

  // Live aggregate from the HomeAdvisor profile. ratingValue rounded to one
  // decimal for display; full precision (4.74) preserved here for parsers.
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: siteConfig.reviewAverage,
    bestRating: 5,
    worstRating: 1,
    reviewCount: siteConfig.reviewCount,
  },

  // sameAs links the LocalBusiness entity across the web. AI parsers and
  // schema validators use this for entity resolution. Add Google Business
  // Profile, Yelp, Facebook, etc. here as URLs are confirmed.
  sameAs: [
    siteConfig.homeAdvisorProfileUrl,
  ].filter(Boolean),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
