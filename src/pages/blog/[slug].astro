---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const data = post.data;
const author = await getEntry(data.author);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': data.schemaType,
  headline: data.title,
  description: data.excerpt,
  datePublished: data.publishedDate.toISOString(),
  dateModified: (data.updatedDate ?? data.publishedDate).toISOString(),
  author: {
    '@type': 'Person',
    name: author?.data.name ?? 'Scott',
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    url: siteConfig.url,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteConfig.url}/blog/` },
    { '@type': 'ListItem', position: 3, name: data.title, item: `${siteConfig.url}/blog/${post.slug}/` },
  ],
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.title} | RCS Gutters`}
  description={data.seoDescription ?? data.excerpt}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="container-x pt-6 text-sm text-ink-muted" aria-label="Breadcrumb">
    <ol class="flex flex-wrap gap-1">
      <li><a href="/" class="hover:underline">Home</a></li>
      <li>›</li>
      <li><a href="/blog/" class="hover:underline">Blog</a></li>
      <li>›</li>
      <li class="text-ink-primary font-medium truncate">{data.title}</li>
    </ol>
  </nav>

  <article class="container-x section-tight">
    <div class="max-w-3xl">
      <p class="text-brand-accent text-xs font-bold uppercase tracking-[0.18em] mb-2 capitalize">
        {data.category} · {data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h1 class="mb-5">{data.title}</h1>
      {author && (
        <div class="flex items-center gap-3 mb-7 pb-5 border-b border-line">
          <div>
            <div class="font-semibold">{author.data.name}</div>
            <div class="text-sm text-ink-muted">{author.data.title}</div>
          </div>
        </div>
      )}
    </div>

    <div class="grid lg:grid-cols-3 gap-10 mt-2">
      <div class="lg:col-span-2 prose-rcs">
        <Content />
      </div>
      <aside class="space-y-5">
        <div class="card p-6 bg-brand-cream">
          <h3 class="font-bold mb-2">Get a quote</h3>
          <p class="text-sm text-ink-muted mb-4">
            Free, written, on-site. Across our entire 8-county Central VA service area.
          </p>
          <a href="/quote/" class="btn-primary w-full text-center">Request Quote</a>
        </div>
      </aside>
    </div>
  </article>

  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto">
      <h2 class="text-white">Want this on your house?</h2>
      <p class="text-white/80 mt-3 mb-6">
        Free written estimate. Honest recommendations. Real local crew.
      </p>
      <a href="/quote/" class="btn-accent">Request a Quote</a>
    </div>
  </section>
</BaseLayout>
