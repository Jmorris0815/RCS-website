---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Picture from '../../components/Picture.astro';

const tierOrder = { economy: 0, standard: 1, premium: 2, luxury: 3 };
const products = (await getCollection('products')).sort(
  (a, b) => (tierOrder[a.data.priceTier] ?? 0) - (tierOrder[b.data.priceTier] ?? 0)
);

// Per-product card thumbnail. Mirrors the hero map in /products/[slug].astro
// so the image and the destination page agree on which product is which.
const PRODUCT_THUMBS: Record<string, { src: string; alt: string }> = {
  'xtreme-gutter-guard': {
    src: '/images/products/OUTSIIDE-CORNER-MITER-INSTALLED.jpg',
    alt: 'Xtreme stainless micro-mesh installed at a corner miter',
  },
  'new-wave-gutter-guard': {
    src: '/images/products/leafsolution/new-wave/installed-fall-wide.jpg',
    alt: 'New Wave punched-aluminum guard installed on a shingle roof',
  },
  'evelyns-leaf-solution': {
    src: '/images/products/leafsolution/evelyns/installed-fall-hero.jpg',
    alt: "Evelyn's Leaf Solution panel installed on a shingle roof in fall",
  },
};
---

<BaseLayout
  title="Leaf Solution Gutter Guards | Authorized Dealer | RCS Gutters"
  description="The three Leaf Solution gutter guard product lines we install: Xtreme stainless micro-mesh, New Wave punched aluminum, and Evelyn's Leaf Solution capillary-dip. Authorized dealer serving Central Virginia."
>
  <section class="container-x section-tight">
    <p class="kicker mb-2">
      Products · Leaf Solution Authorized Dealer
    </p>
    <h1 class="mb-4">Three gutter guard products. One that's right for your home.</h1>
    <span class="hero-underline !mt-0 mb-6"></span>
    <p class="text-fluid-lg text-ink-muted max-w-3xl">
      We install the full Leaf Solution lineup, and we'll tell you straight which one fits your specific tree mix and budget. The most expensive product isn't always the best fit.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/configurator/" class="btn-primary">Try the Configurator Quiz</a>
      <a href="/quote/" class="btn-secondary">Get a Free Quote</a>
    </div>
  </section>

  <!-- Parts diagram -->
  <section class="bg-brand-cream section">
    <div class="container-x grid lg:grid-cols-12 gap-10 items-center reveal">
      <div class="lg:col-span-7">
        <img
          src="/images/products/rcs-parts-diagram.jpg"
          alt="RCS parts diagram showing end cap, outside miter, gutter guard, straight miter, inside miter, inside bay miter, outside bay miter, and downspout cap labeled on a sample home"
          class="w-full h-auto rounded-2xl shadow-card"
          loading="lazy" width="1400" height="1050"
        />
      </div>
      <div class="lg:col-span-5">
        <span class="section-divider"></span>
        <p class="kicker mb-3">Anatomy of a complete system</p>
        <h2 class="text-balance mb-5">A gutter is more than a piece of aluminum.</h2>
        <p class="text-ink-muted leading-relaxed mb-4">
          A complete seamless system is built from a half-dozen specialized parts that have to work together. Miters at every corner, end caps, straight runs, downspout transitions, and the gutter guard itself. We custom-fabricate the runs on site and pair every system with the right Leaf Solution panel for your tree mix.
        </p>
        <p class="text-[12px] text-ink-subtle">
          Diagram shows the named parts of a typical residential install. Illustrated reference; your home will have its own combination of these elements.
        </p>
      </div>
    </div>
  </section>

  <section class="container-x section">
    <div class="grid lg:grid-cols-3 gap-6">
      {products.map((p) => {
        const thumb = PRODUCT_THUMBS[p.slug];
        return (
          <a href={`/products/${p.slug}/`} class="card overflow-hidden block group flex flex-col">
            {thumb && (
              <div class="relative overflow-hidden aspect-[16/10] bg-brand-warm-gray">
                <Picture
                  src={thumb.src}
                  alt={thumb.alt}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  width={800} height={500}
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-7 flex-1 flex flex-col">
              <div class="text-xs font-bold uppercase text-brand-primary tracking-wider mb-2 capitalize">
                {p.data.priceTier} tier
              </div>
              <h2 class="text-2xl font-bold mb-2 group-hover:text-brand-primary transition">
                {p.data.title}
              </h2>
              <p class="text-ink-muted text-sm mb-5 flex-1">{p.data.tagline}</p>
              <div class="grid grid-cols-2 gap-2 text-xs text-ink-muted mb-5">
                <div>
                  <span class="font-bold text-ink-primary tabular-nums">{p.data.gpmCapacity ?? '—'}</span> GPM
                </div>
                <div>
                  <span class="font-bold text-ink-primary tabular-nums">{p.data.warrantyYears ?? '—'}</span> yr warranty
                </div>
              </div>
              <span class="text-brand-primary font-semibold text-sm">View product →</span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="section bg-brand-cream">
    <div class="container-x max-w-3xl">
      <h2 class="mb-4">Why Leaf Solution?</h2>
      <p class="text-ink-muted mb-3">
        We chose Leaf Solution as our primary gutter guard partner for three reasons. <strong>First</strong>, the factory is in Rochelle, VA. About thirty minutes from our shop. So when there's a warranty question or a special-order color, we have a relationship rather than a 1-800 number. <strong>Second</strong>, they only sell to authorized contractors, which means installation quality stays consistent across their dealer network and customers don't get a DIY product slapped on by a handyman. <strong>Third</strong>, the products perform. We've installed enough of them across Central Virginia to know which ones survive which debris loads, and the failures we see in the market are almost always the cheaper non-Leaf Solution alternatives we end up tearing off.
      </p>
      <p class="text-ink-muted">
        We don't have an exclusive arrangement with Leaf Solution. We just don't think the alternatives are worth selling.
      </p>
    </div>
  </section>
</BaseLayout>
