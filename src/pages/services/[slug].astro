---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/schemas/FAQSchema.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((s) => ({ params: { slug: s.slug }, props: { svc: s } }));
}

const { svc } = Astro.props;
const { Content } = await svc.render();
const data = svc.data;

// Slug → hero photo map. Only includes services where we have an honest matching shot.
const HERO_PHOTOS: Record<string, { src: string; alt: string }> = {
  'seamless-gutter-installation': {
    src: '/images/products/OUTSIIDE-CORNER-MITER-INSTALLED.jpg',
    alt: 'Corner miter on a freshly installed seamless aluminum gutter, autumn leaves in background',
  },
  'gutter-cleaning': {
    src: '/images/jobs/clogged-leaves.jpg',
    alt: 'A shingle-roof gutter packed with red and brown autumn leaves',
  },
  'gutter-guards': {
    src: '/images/products/straight-miter-fall-background.jpg',
    alt: 'Leaf Solution gutter guard installed on a shingle roof above a fall lawn',
  },
  'fascia-and-soffit': {
    src: '/images/jobs/rotted-roof-deck.jpg',
    alt: 'Rotted roof deck and ceiling joists viewed from below — typical fascia-failure damage',
  },
};
const hero = HERO_PHOTOS[svc.slug];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${siteConfig.url}/services/` },
    { '@type': 'ListItem', position: 3, name: data.title, item: `${siteConfig.url}/services/${svc.slug}/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: data.title,
  description: data.description,
  provider: { '@id': `${siteConfig.url}/#business` },
  areaServed: [
    'Charlottesville, VA', 'Albemarle County, VA', 'Barboursville, VA',
    'Orange County, VA', 'Madison County, VA', 'Greene County, VA',
    'Fluvanna County, VA', 'Louisa County, VA',
  ],
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.title} | RCS Gutters`}
  description={data.seoDescription ?? data.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <FAQSchema faqs={data.faqs} />
  </Fragment>

  <nav class="container-x pt-6 text-sm text-ink-muted" aria-label="Breadcrumb">
    <ol class="flex flex-wrap gap-1">
      <li><a href="/" class="hover:underline">Home</a></li>
      <li>›</li>
      <li><a href="/services/" class="hover:underline">Services</a></li>
      <li>›</li>
      <li class="text-ink-primary font-medium">{data.title}</li>
    </ol>
  </nav>

  <section class="container-x section-tight">
    <div class={hero ? 'grid lg:grid-cols-12 gap-10 items-center' : ''}>
      <div class={hero ? 'lg:col-span-6' : ''}>
        <p class="text-brand-primary text-xs font-bold uppercase tracking-[0.18em] mb-2">
          Service · Central Virginia
        </p>
        <h1 class="mb-4">{data.title}</h1>
        <p class="text-fluid-lg text-ink-muted max-w-3xl">{data.tagline}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/quote/" class="btn-primary">Get a Free Quote</a>
          <a href={`tel:${siteConfig.phoneRaw}`} class="btn-secondary">Call {siteConfig.phoneDisplay}</a>
        </div>
      </div>
      {hero && (
        <div class="lg:col-span-6">
          <img
            src={hero.src}
            alt={hero.alt}
            class="w-full h-auto rounded-xl shadow-card object-cover aspect-[4/3]"
            loading="eager"
            fetchpriority="high"
            width="1400"
            height="1050"
          />
        </div>
      )}
    </div>
  </section>

  <section class="bg-brand-cream section">
    <div class="container-x grid lg:grid-cols-3 gap-10">
      <article class="lg:col-span-2 prose-rcs">
        <Content />
      </article>
      <aside class="space-y-5">
        <div class="card p-6 bg-white">
          <h3 class="text-lg font-bold mb-3">Free, no-pressure estimate</h3>
          <p class="text-sm text-ink-muted mb-4">
            We come walk your property, measure, and give you a written quote on the spot or within 24 hours. Same pricing across our entire 8-county service area.
          </p>
          <a href="/quote/" class="btn-primary w-full text-center">Request Quote</a>
          <a href={`tel:${siteConfig.phoneRaw}`} class="block text-center mt-3 text-brand-primary font-semibold">
            Or call {siteConfig.phoneDisplay}
          </a>
        </div>
        <div class="card p-6 bg-white">
          <h3 class="text-lg font-bold mb-3">Where we work</h3>
          <ul class="text-sm space-y-1 text-ink-muted">
            <li><a class="hover:underline" href="/locations/charlottesville/">Charlottesville</a></li>
            <li><a class="hover:underline" href="/locations/albemarle/">Albemarle County</a></li>
            <li><a class="hover:underline" href="/locations/barboursville/">Barboursville</a></li>
            <li><a class="hover:underline" href="/locations/orange/">Orange County</a></li>
            <li><a class="hover:underline" href="/locations/madison/">Madison County</a></li>
            <li><a class="hover:underline" href="/locations/greene/">Greene County</a></li>
            <li><a class="hover:underline" href="/locations/fluvanna/">Fluvanna County</a></li>
            <li><a class="hover:underline" href="/locations/louisa/">Louisa County</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  {data.faqs.length > 0 && (
    <section class="section container-x max-w-3xl">
      <h2 class="mb-6">Frequently asked questions</h2>
      <div class="space-y-3">
        {data.faqs.map((f) => (
          <details class="card p-5">
            <summary class="font-semibold cursor-pointer">{f.question}</summary>
            <p class="mt-3 text-ink-muted">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto">
      <h2 class="text-white">Ready when you are.</h2>
      <p class="text-white/95 mt-3 mb-6">
        Free written estimate. Honest recommendations. Real local crew.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote/" class="btn-accent">Get a Quote</a>
        <a href={`tel:${siteConfig.phoneRaw}`} class="btn-secondary !text-white !border-white hover:!bg-white hover:!text-brand-primary">
          {siteConfig.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
