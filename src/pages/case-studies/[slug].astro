---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PictureHero from '../../components/PictureHero.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((cs) => ({ params: { slug: cs.slug }, props: { study: cs } }));
}

const { study } = Astro.props;
const { Content } = await study.render();
const data = study.data;
const author = await getEntry(data.author);

const HERO_PHOTOS: Record<string, { src: string; alt: string }> = {
  'charlottesville-tulip-poplar-xtreme-upgrade': {
    src: '/images/jobs/before-after-cleaning.jpg',
    alt: 'Before-and-after split: gutter packed with brown tulip-poplar leaves vs. clean micro-mesh after upgrade',
  },
  'greene-pine-forest-cleaning-rescue': {
    src: '/images/jobs/clogged-leaves.jpg',
    alt: 'A shingle-roof gutter packed with autumn leaves and pine needles before cleaning',
  },
  'madison-farmhouse-half-round-restoration': {
    src: '/images/jobs/gutter-pulling-away.jpg',
    alt: 'A failed older gutter pulling away from the roofline of a farmhouse before restoration',
  },
  'albemarle-vineyard-multi-building-drainage': {
    src: '/images/jobs/install-modern-board-batten.jpg',
    alt: 'Modern board-and-batten outbuilding with new gutters — representative of the multi-building scope on this Albemarle vineyard project',
  },
};
const hero = HERO_PHOTOS[study.slug];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Our Work', item: `${siteConfig.url}/case-studies/` },
    { '@type': 'ListItem', position: 3, name: data.title, item: `${siteConfig.url}/case-studies/${study.slug}/` },
  ],
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.title} | RCS Gutters`}
  description={data.seoDescription ?? data.problem.slice(0, 160)}
  heroImage={hero?.src}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="container-x pt-6 text-sm text-ink-muted" aria-label="Breadcrumb">
    <ol class="flex flex-wrap gap-1">
      <li><a href="/" class="hover:underline">Home</a></li>
      <li>›</li>
      <li><a href="/case-studies/" class="hover:underline">Our Work</a></li>
      <li>›</li>
      <li class="text-brand-charcoal font-medium truncate">{data.title}</li>
    </ol>
  </nav>

  <article class="container-x section-tight">
    <div class="max-w-3xl reveal">
      <p class="kicker mb-3">
        {data.customerCity}{data.customerCounty ? `, ${data.customerCounty} County` : ''} · {data.dateCompleted.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
      </p>
      <h1 class="mb-5 text-balance">{data.title}</h1>
      <span class="hero-underline !mt-0"></span>
    </div>

    {hero && (
      <div class="mt-8 reveal">
        <PictureHero
          base={hero.src.replace(/\.(jpg|jpeg|png)$/i, '')}
          alt={hero.alt}
          class="w-full h-auto rounded-2xl shadow-card object-cover aspect-[16/9]"
          loading="eager" fetchpriority="high"
          width={1280} height={720}
        />
      </div>
    )}

    <div class="grid lg:grid-cols-12 gap-10 mt-12">
      <div class="lg:col-span-8 prose-rcs reveal">
        <h2>The problem</h2>
        <p>{data.problem}</p>
        <h2>What we did</h2>
        <p>{data.solution}</p>
        <h2>How it turned out</h2>
        <p>{data.outcome}</p>
        <Content />
        {data.customerQuote && data.permissionGranted && (
          <blockquote class="font-display text-fluid-xl border-l-4 border-brand-primary pl-6 my-8 not-italic text-brand-charcoal">
            "{data.customerQuote}"
            {data.customerName && (
              <cite class="block mt-3 text-sm text-ink-muted not-italic font-sans">— {data.customerName}, {data.customerCity}</cite>
            )}
          </blockquote>
        )}
      </div>
      <aside class="lg:col-span-4 space-y-5 self-start lg:sticky lg:top-20">
        <div class="card p-6 bg-brand-cream">
          <p class="kicker-charcoal mb-3">Project facts</p>
          <dl class="text-sm space-y-3">
            <div>
              <dt class="text-[11px] text-brand-warm-gray uppercase tracking-wider">Location</dt>
              <dd class="font-semibold text-brand-charcoal">{data.customerCity}, VA</dd>
            </div>
            <div>
              <dt class="text-[11px] text-brand-warm-gray uppercase tracking-wider">Completed</dt>
              <dd class="font-semibold text-brand-charcoal">{data.dateCompleted.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</dd>
            </div>
            {author && (
              <div>
                <dt class="text-[11px] text-brand-warm-gray uppercase tracking-wider">Crew lead</dt>
                <dd class="font-semibold text-brand-charcoal">{author.data.name}</dd>
              </div>
            )}
          </dl>
        </div>
        <div class="card p-6">
          <p class="kicker-charcoal mb-3">Want similar work?</p>
          <p class="text-sm text-ink-muted mb-5 leading-relaxed">
            Every house is different. Get a free quote and we'll walk yours.
          </p>
          <a href="/quote/" class="btn-primary w-full justify-center">Request Quote</a>
        </div>
      </aside>
    </div>
  </article>

  <!-- Final CTA -->
  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto reveal">
      <p class="kicker !text-brand-gold-soft mb-3">Want this on your house?</p>
      <h2 class="font-display text-white text-balance mb-5">Free written estimate.</h2>
      <p class="text-white/95 text-fluid-lg mb-7 leading-relaxed">
        Honest recommendations. Real local crew.
      </p>
      <a href="/quote/" class="btn-accent">Request a Quote</a>
    </div>
  </section>
</BaseLayout>
