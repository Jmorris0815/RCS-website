---
import LandingLayout from '../layouts/LandingLayout.astro';
import Picture from '../components/Picture.astro';
import { siteConfig } from '../config/site';
import MultiStepForm from '../components/landing/MultiStepForm.tsx';
import Reveal from '../components/landing/Reveal.tsx';
import AnimatedCounter from '../components/landing/AnimatedCounter.tsx';
import StickyMobileCTA from '../components/landing/StickyMobileCTA.tsx';
import ScrollProgress from '../components/landing/ScrollProgress.tsx';

// Pre-resolved at build time so the React island gets the value as a string prop.
const adsConvId = import.meta.env.PUBLIC_GADS_CONVERSION_ID || '';
const adsConvLabel = import.meta.env.PUBLIC_GADS_CONVERSION_LABEL || '';
const adsSendTo = adsConvId && adsConvLabel ? `${adsConvId}/${adsConvLabel}` : '';

// "Whatever your gutters need" service catalog. Inline SVGs over Lucide React
// to avoid hydrating a React island per icon.
const services = [
  {
    title: 'Seamless Gutter Installation',
    sub: 'Custom-cut on site. Residential + commercial.',
    thumb: '/images/jobs/install-gray-ranch.jpg',
    icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />',
  },
  {
    title: 'Gutter Guards & Leaf Protection',
    sub: 'Leaf Solution authorized installer. Three brands available.',
    thumb: '/images/products/leafsolution/new-wave/installed-fall-wide.jpg',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />',
  },
  {
    title: 'Gutter Cleaning',
    sub: 'Hand-cleared, debris hauled away, flow tested.',
    thumb: '/images/jobs/cleaning-hand-removal.jpg',
    icon: '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3L12 3z" /><path d="M5 3v4" /><path d="M19 17v4" /><path d="M3 5h4" /><path d="M17 19h4" />',
  },
  {
    title: 'Gutter Brightening',
    sub: 'Removes black streaks. Restores original finish.',
    thumb: '/images/jobs/before-after-cleaning.jpg',
    icon: '<circle cx="12" cy="12" r="4" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />',
  },
  {
    title: 'Fascia & Soffit Repair',
    sub: 'Rotted wood fixed in-line during install.',
    thumb: '/images/jobs/rotted-roof-deck.jpg',
    icon: '<path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9" /><path d="m18 15 4-4" /><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5" />',
  },
  {
    title: 'Drainage & Downspouts',
    sub: 'Underground drainage. Splash blocks. Foundation kept dry.',
    thumb: '/images/jobs/install-downspout-sage-clapboard.jpg',
    icon: '<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z" /><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97" />',
  },
  {
    title: 'Gutter Repairs',
    sub: 'Sagging, leaking, pulling away — fixed same week.',
    thumb: '/images/jobs/gutter-pulling-away.jpg',
    icon: '<circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />',
  },
  {
    title: 'Commercial Properties',
    sub: 'Apartment complexes, HOAs, retail, churches. Fully equipped.',
    thumb: '/images/jobs/truck-commercial-flatroof.jpg',
    icon: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /><path d="M10 6h4" /><path d="M10 10h4" /><path d="M10 14h4" /><path d="M10 18h4" />',
  },
];

// Recent installs gallery — every photo lives in /public/images/jobs.
const gallery = [
  { src: '/images/jobs/install-copper-brick-home.jpg', alt: 'Copper gutters on brick home — Charlottesville', city: 'Charlottesville' },
  { src: '/images/jobs/install-modern-board-batten.jpg', alt: 'Modern board-and-batten install — Crozet', city: 'Crozet' },
  { src: '/images/jobs/install-gray-ranch-screened-porch.jpg', alt: 'Gray ranch with screened porch — Albemarle', city: 'Albemarle' },
  { src: '/images/jobs/install-brick-and-blue-siding.jpg', alt: 'Brick + blue siding — Fluvanna', city: 'Fluvanna' },
  { src: '/images/jobs/install-downspout-sage-clapboard.jpg', alt: 'Downspout detail, sage clapboard — Greene', city: 'Greene' },
  { src: '/images/jobs/install-soffit-detail.jpg', alt: 'Soffit + drip edge detail', city: 'Soffit detail' },
  { src: '/images/jobs/install-copper-federal-brick.jpg', alt: 'Copper on federal brick', city: 'Federal brick' },
  { src: '/images/jobs/install-dark-clad-barn.jpg', alt: 'Dark-clad barn install', city: 'Barn install' },
];
---

<LandingLayout
  title="Free Gutter Estimate — Charlottesville & Albemarle | RCS Gutters"
  description="Get on Scott's calendar this week. Real written quote on the spot, install in one day, lifetime warranty. Family-run since 2014."
>
  <ScrollProgress client:load />

  {/* ============================ HERO ============================ */}
  <section class="container-x pt-8 pb-12 lg:pt-14 lg:pb-20 relative overflow-hidden">
    <div aria-hidden="true" class="absolute -top-32 -right-40 w-[640px] h-[640px] bg-brand-light rounded-full blur-3xl opacity-60 pointer-events-none"></div>

    <div class="relative grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      {/* Hero content — left 7/12 */}
      <div class="lg:col-span-7 lg:pt-4">
        <Reveal client:visible>
          <p class="kicker mb-3 inline-flex items-center gap-2 flex-wrap">
            <span class="text-amber-500 tracking-tight">★ 4.9</span>
            <span>from</span>
            <span class="font-bold text-ink-primary">
              <AnimatedCounter to={87} client:visible />+
            </span>
            <span>Google reviews — and counting</span>
          </p>
          <h1 class="text-fluid-4xl lg:text-[clamp(2.75rem,2.2rem+2.6vw,4.5rem)] leading-[1.05] mb-5 font-display">
            Seamless gutters that <span class="text-brand-primary">actually last 30 years</span>.
          </h1>
          <p class="text-fluid-lg text-ink-muted mb-7 max-w-xl leading-relaxed">
            In about 30 seconds, get on Scott's calendar this week. Real written quote on the spot. Install in one day. Never think about gutters again. Lifetime warranty included.
          </p>
        </Reveal>

        {/* Stats row */}
        <Reveal client:visible delay={0.1}>
          <div class="grid grid-cols-3 gap-4 max-w-xl mb-8 border-y border-line py-5">
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={1200} client:visible />+
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Homes installed</div>
            </div>
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={12} client:visible />
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Years in Central VA</div>
            </div>
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={100} client:visible />%
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Lifetime warranty</div>
            </div>
          </div>
        </Reveal>

        {/* Hero photo — Scott in front of the green truck */}
        <Reveal client:visible delay={0.15}>
          <div class="relative rounded-xl overflow-hidden mb-7 max-w-xl shadow-card">
            <Picture
              src="/images/team/scott.jpg"
              alt="Scott Smith, RCS owner — on every estimate personally"
              width={800}
              height={1000}
              loading="eager"
              fetchpriority="high"
              class="w-full h-auto block"
            />
            <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/65 to-transparent text-white">
              <p class="text-sm font-semibold tracking-tight">Scott Smith — Owner</p>
              <p class="text-xs opacity-85">On every estimate. Personally.</p>
            </div>
          </div>
        </Reveal>

        {/* What happens next */}
        <Reveal client:visible delay={0.2}>
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-wider font-bold text-ink-muted mb-3">What happens next</p>
            <ol class="grid sm:grid-cols-3 gap-3 text-sm">
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">1</span>
                <span><strong>You submit</strong> — 30 seconds.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">2</span>
                <span><strong>Scott calls</strong> within one business day.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">3</span>
                <span><strong>15-min walk-around.</strong> Real number same day.</span>
              </li>
            </ol>
          </div>
        </Reveal>
      </div>

      {/* Form column — right 5/12. Stack box anchors visually above the form. */}
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-32 space-y-0">
          {/* HORMOZI STACK — sits above the form, anchored visually */}
          <div class="rounded-t-xl bg-brand-cream border-x border-t border-line p-5 lg:p-6">
            <p class="kicker mb-3 text-center">When you submit, you get</p>
            <ul class="space-y-2 text-sm">
              <li class="flex items-start gap-2.5">
                <svg class="text-brand-primary flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7" /></svg>
                <span>Scott on the phone within one business day</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="text-brand-primary flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7" /></svg>
                <span>15-minute on-site walk-around — at no cost</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="text-brand-primary flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7" /></svg>
                <span>A real written quote, same day</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="text-brand-primary flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7" /></svg>
                <span>No high-pressure sales — sleep on it as long as you want</span>
              </li>
              <li class="flex items-start gap-2.5">
                <svg class="text-brand-primary flex-shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7" /></svg>
                <span>If you book: install often within the same week</span>
              </li>
            </ul>
          </div>
          {/* The form card sits flush below — share rounded-bottom with stack-top */}
          <div class="[&>form]:rounded-t-none [&>form]:border-t-0">
            <MultiStepForm
              client:load
              adsSendTo={adsSendTo}
              phoneRaw={siteConfig.phoneRaw}
              phoneDisplay={siteConfig.phoneDisplay}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================ TRUST STRIP ============================ */}
  <section class="bg-brand-cream border-y border-line">
    <div class="container-x py-7">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-5 text-center">
        {[
          { value: '★ 4.9', label: 'Google Reviews' },
          { value: 'BBB A+', label: 'Accredited' },
          { value: '$1M', label: 'General Liability Insured' },
          { value: 'VA Class A', label: 'Licensed Contractor' },
          { value: '12 Years', label: 'Family-Owned in VA' },
          { value: 'Lifetime', label: 'Craftsmanship Warranty' },
        ].map((card, i) => (
          <Reveal client:visible delay={i * 0.06}>
            <div class="flex flex-col items-center group">
              <span class="text-brand-primary font-display font-bold text-xl tracking-tight">{card.value}</span>
              <span class="text-[11px] text-ink-muted uppercase tracking-wide mt-1 leading-tight">{card.label}</span>
              <span class="block w-8 h-0.5 bg-brand-primary/0 group-hover:bg-brand-primary/60 mt-2 transition-colors"></span>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* ============================ VALUE STACK ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="text-center mb-12 max-w-3xl mx-auto">
        <p class="kicker mb-3">What's included</p>
        <h2 class="text-fluid-3xl">Here's exactly what your install includes — no upsells, no surprises.</h2>
        <p class="text-ink-muted mt-3">What you see at the estimate is what's on your invoice.</p>
      </div>
    </Reveal>

    <div class="max-w-3xl mx-auto">
      <ul class="divide-y divide-line border-y border-line">
        {[
          { label: 'Heavy-gauge .032 aluminum gutters (most installers use thinner .027)', tag: 'Heavy-duty standard' },
          { label: 'Hidden hangers rated 150+ lbs (most still use spike-and-ferrule)', tag: '150 lb hold strength' },
          { label: 'Full fascia inspection + in-line repair if needed', tag: 'No upcharge if rotted' },
          { label: 'Custom-cut on site for perfect-length, no-seam runs', tag: 'Custom-fit, no seams' },
          { label: 'Same-week scheduling guaranteed (or your install is $200 off)', tag: 'Locked-in week' },
          { label: 'Lifetime craftsmanship warranty', tag: 'As long as you own the home' },
          { label: '$1M general liability insurance protecting your home', tag: 'Included' },
          { label: 'Background-checked, in-house crew (no day labor)', tag: 'Included' },
        ].map((item, i) => (
          <Reveal client:visible delay={i * 0.04}>
            <li class="flex items-start gap-4 py-4">
              <span class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-accent-success/15 text-accent-success flex items-center justify-center" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12l5 5L20 7" />
                </svg>
              </span>
              <span class="flex-1 text-base lg:text-lg">{item.label}</span>
              <span class="flex-shrink-0 font-display font-semibold text-brand-primary text-xs sm:text-sm uppercase tracking-wide whitespace-nowrap pt-1">
                {item.tag}
              </span>
            </li>
          </Reveal>
        ))}
      </ul>

      <Reveal client:visible>
        <div class="text-center mt-8">
          <a href="#rcs-fe-form" class="btn-primary text-base">
            Get My Free Estimate — Lock In These Inclusions →
          </a>
        </div>
      </Reveal>
    </div>
  </section>

  {/* ============================ TRIPLE PROMISE ============================ */}
  <section class="bg-brand-charcoal text-white">
    <div class="container-x section">
      <Reveal client:visible>
        <div class="text-center mb-12 max-w-2xl mx-auto">
          <p class="kicker !text-brand-primary mb-3">The RCS Triple Promise</p>
          <h2 class="text-white text-fluid-3xl">Three commitments. In writing. On every job.</h2>
        </div>
      </Reveal>
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        {[
          {
            title: 'Same-Week Scheduling',
            body: "If we can't get you on the schedule within 7 days of your accepted estimate, your install is $200 off. Period.",
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><path d="M9 16l2 2 4-4" />
              </svg>
            ),
          },
          {
            title: 'Lifetime Craftsmanship',
            body: 'If our work fails for as long as you own the home, we come back and fix it. Free. No "warranty service fee" tricks.',
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            ),
          },
          {
            title: 'No-Surprise Pricing',
            body: 'Your estimate is the price you pay. No "we found rot, that\'ll be another $800" on install day. We inspect first, quote real, install on budget.',
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            ),
          },
        ].map((p, i) => (
          <Reveal client:visible delay={i * 0.1}>
            <div class="p-6 lg:p-7 bg-white/5 border border-white/10 rounded-xl h-full">
              <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center mb-4">
                {p.icon}
              </div>
              <h3 class="text-white text-xl mb-3">{p.title}</h3>
              <p class="text-white/75 leading-relaxed text-sm">{p.body}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* ============================ SERVICE CATALOG ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="kicker mb-3">The full catalog</p>
        <h2 class="text-fluid-3xl">Whatever your gutters need, we do it.</h2>
      </div>
    </Reveal>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5 max-w-6xl mx-auto">
      {services.map((svc, i) => (
        <Reveal client:visible delay={i * 0.05}>
          <a
            href="#rcs-fe-form"
            class="group block bg-white border border-line rounded-xl overflow-hidden hover:shadow-card hover:-translate-y-0.5 transition-all duration-200 h-full"
          >
            {/* Optional thumb in corner */}
            <div class="aspect-[16/9] bg-brand-cream overflow-hidden">
              <Picture
                src={svc.thumb}
                alt={svc.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-3 mb-2">
                <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-brand-light text-brand-primary flex items-center justify-center" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={svc.icon} />
                </span>
                <h3 class="text-base font-bold leading-tight">{svc.title}</h3>
              </div>
              <p class="text-sm text-ink-muted leading-relaxed mb-3">{svc.sub}</p>
              <span class="text-xs font-bold text-brand-primary group-hover:translate-x-1 inline-block transition-transform">
                Get a quote →
              </span>
            </div>
          </a>
        </Reveal>
      ))}
    </div>

    <Reveal client:visible>
      <p class="text-center mt-10 text-base lg:text-lg text-ink-muted max-w-2xl mx-auto">
        One call, one crew, one warranty across every service. Family-run since 2014.
      </p>
    </Reveal>
  </section>

  {/* ============================ WHY RCS ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="kicker mb-3">Why homeowners pick RCS</p>
