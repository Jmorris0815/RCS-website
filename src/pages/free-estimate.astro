---
import LandingLayout from '../layouts/LandingLayout.astro';
import { siteConfig } from '../config/site';
import MultiStepForm from '../components/landing/MultiStepForm.tsx';
import Reveal from '../components/landing/Reveal.tsx';
import AnimatedCounter from '../components/landing/AnimatedCounter.tsx';
import StickyMobileCTA from '../components/landing/StickyMobileCTA.tsx';
import ScrollProgress from '../components/landing/ScrollProgress.tsx';

// Pre-resolved at build time so the React island gets the value as a string
// prop (avoids leaking import.meta.env into client bundle indirectly).
const adsConvId = import.meta.env.PUBLIC_GADS_CONVERSION_ID || '';
const adsConvLabel = import.meta.env.PUBLIC_GADS_CONVERSION_LABEL || '';
const adsSendTo = adsConvId && adsConvLabel ? `${adsConvId}/${adsConvLabel}` : '';
---

<LandingLayout
  title="Free Gutter Estimate — Charlottesville & Albemarle | RCS Gutters"
  description="Free, same-week gutter estimate. Family-run since 2014, 4.9 stars on Google, lifetime craftsmanship warranty. Seamless gutters built to last 30 years."
>
  {/* Scroll progress bar — slim red sliver at the top of the viewport. */}
  <ScrollProgress client:load />

  {/* ============================ HERO ============================ */}
  <section class="container-x pt-8 pb-12 lg:pt-14 lg:pb-20 relative overflow-hidden">
    {/* Decorative diagonal accent — purely visual */}
    <div aria-hidden="true" class="absolute -top-32 -right-40 w-[640px] h-[640px] bg-brand-light rounded-full blur-3xl opacity-60 pointer-events-none"></div>

    <div class="relative grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      {/* Hero content — left 7/12 */}
      <div class="lg:col-span-7 lg:pt-4">
        <Reveal client:visible>
          <p class="kicker mb-3 inline-flex items-center gap-2">
            <span class="text-amber-500 tracking-tight">★ 4.9</span>
            <span>from</span>
            <span class="font-bold text-ink-primary">
              <AnimatedCounter to={87} client:visible />+
            </span>
            <span>Google reviews — and counting</span>
          </p>
          <h1 class="text-fluid-4xl lg:text-[clamp(2.5rem,2rem+2.5vw,4.25rem)] leading-[1.05] mb-5 font-display">
            Seamless gutters that <span class="text-brand-primary">actually last 30 years</span>.
          </h1>
          <p class="text-fluid-lg text-ink-muted mb-7 max-w-xl leading-relaxed">
            Family-run since 2014. 4.9 stars on Google. Lifetime craftsmanship warranty. Same-week estimates across Central Virginia.
          </p>
        </Reveal>

        {/* Stats row */}
        <Reveal client:visible delay={0.1}>
          <div class="grid grid-cols-3 gap-4 max-w-xl mb-8 border-y border-line py-5">
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={1200} client:visible />+
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Homes installed</div>
            </div>
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={12} client:visible />
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Years in Central VA</div>
            </div>
            <div>
              <div class="font-display text-2xl lg:text-3xl font-bold text-brand-primary">
                <AnimatedCounter to={100} client:visible />%
              </div>
              <div class="text-xs uppercase tracking-wide text-ink-muted mt-1">Lifetime warranty</div>
            </div>
          </div>
        </Reveal>

        {/* Hero visual — placeholder for Scott + truck photo + video play overlay.
             Justin to swap the background-image style with the real photo path. */}
        {/* TODO: VERIFY WITH SCOTT — swap placeholder for real photo of Scott in front of the green truck */}
        <Reveal client:visible delay={0.15}>
          <div class="relative aspect-[16/10] lg:aspect-[16/9] rounded-xl overflow-hidden mb-7 bg-gradient-to-br from-brand-charcoal via-brand-charcoal to-brand-primary/40 max-w-xl">
            <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center p-6">
              <p class="font-display text-xl mb-2 opacity-90">[ Scott + the green RCS truck — photo coming ]</p>
              <p class="text-sm opacity-70 mb-5">Justin will drop in the real shot.</p>
              <button
                type="button"
                aria-label="Play Scott's intro video"
                class="w-16 h-16 rounded-full bg-white/95 text-brand-primary flex items-center justify-center hover:scale-105 transition-transform shadow-2xl"
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7L8 5z" />
                </svg>
              </button>
              <p class="text-xs mt-3 opacity-80">60-sec intro from Scott (placeholder)</p>
            </div>
          </div>
        </Reveal>

        {/* What happens next — anxiety killer */}
        <Reveal client:visible delay={0.2}>
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-wider font-bold text-ink-muted mb-3">What happens next</p>
            <ol class="grid sm:grid-cols-3 gap-3 text-sm">
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">1</span>
                <span><strong>You submit</strong> — takes 30 sec.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">2</span>
                <span><strong>Scott calls</strong> within 1 business day.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-primary text-white font-bold flex items-center justify-center text-xs">3</span>
                <span><strong>15-min walk-around</strong> + real number same day.</span>
              </li>
            </ol>
          </div>
        </Reveal>

        {/* Live-feel social proof — static for now, swap for real GHL counter later */}
        {/* TODO: VERIFY WITH SCOTT — wire to real GHL contact count after launch */}
        <Reveal client:visible delay={0.3}>
          <div class="mt-6 inline-flex items-center gap-2 text-sm text-ink-muted">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-success opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent-success"></span>
            </span>
            <span><strong class="text-ink-primary">3 homeowners</strong> booked an estimate today</span>
          </div>
        </Reveal>
      </div>

      {/* Form column — right 5/12, sticky on desktop */}
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-32">
          <MultiStepForm
            client:load
            adsSendTo={adsSendTo}
            phoneRaw={siteConfig.phoneRaw}
            phoneDisplay={siteConfig.phoneDisplay}
          />
        </div>
      </div>
    </div>
  </section>

  {/* ============================ TRUST STRIP ============================ */}
  <section class="bg-brand-cream border-y border-line">
    <div class="container-x py-7">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-5 text-center">
        {[
          { value: '★ 4.9', label: 'Google Reviews' },
          { value: 'BBB A+', label: 'Accredited' },
          { value: '$1M', label: 'General Liability Insured' },
          { value: 'VA Class A', label: 'Licensed Contractor' },
          { value: '12 Years', label: 'Family-Owned in VA' },
          { value: 'Lifetime', label: 'Craftsmanship Warranty' },
        ].map((card, i) => (
          <Reveal client:visible delay={i * 0.06}>
            <div class="flex flex-col items-center group">
              <span class="text-brand-primary font-display font-bold text-xl tracking-tight">{card.value}</span>
              <span class="text-[11px] text-ink-muted uppercase tracking-wide mt-1 leading-tight">{card.label}</span>
              <span class="block w-8 h-0.5 bg-brand-primary/0 group-hover:bg-brand-primary/60 mt-2 transition-colors"></span>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* ============================ VALUE STACK (Brunson centerpiece) ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="text-center mb-12 max-w-3xl mx-auto">
        <p class="kicker mb-3">Here's everything you get</p>
        <h2 class="text-fluid-3xl">When RCS installs your gutters, this is the package.</h2>
        <p class="text-ink-muted mt-3">No bait-and-switch line items. What we say at the estimate is what's on your invoice.</p>
      </div>
    </Reveal>

    <div class="max-w-3xl mx-auto">
      {/* TODO: VERIFY WITH SCOTT — every dollar value below is a placeholder. Confirm before publishing. */}
      <ul class="divide-y divide-line border-y border-line">
        {[
          { label: 'Heavy-gauge .032 aluminum gutters (most installers use thinner .027)', value: '$1,200 value' },
          { label: 'Hidden hangers rated 150+ lbs (most still use spike-and-ferrule)', value: '$400 value' },
          { label: 'Full fascia inspection + in-line repair if needed', value: '$650 value' },
          { label: 'Custom-cut on site for perfect-length, no-seam runs', value: '$300 value' },
          { label: 'Same-week scheduling guaranteed (or your install is $200 off)', value: 'Priceless' },
          { label: 'Lifetime craftsmanship warranty — as long as you own the home', value: 'Priceless' },
          { label: '$1M general liability insurance protecting your home', value: 'Included' },
          { label: 'Background-checked, in-house crew (no day labor)', value: 'Included' },
        ].map((item, i) => (
          <Reveal client:visible delay={i * 0.04}>
            <li class="flex items-start gap-4 py-4">
              <span class="flex-shrink-0 mt-1 w-6 h-6 rounded-full bg-accent-success/15 text-accent-success flex items-center justify-center" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12l5 5L20 7" />
                </svg>
              </span>
              <span class="flex-1 text-base lg:text-lg">{item.label}</span>
              <span class="flex-shrink-0 font-display font-bold text-brand-primary text-sm sm:text-base whitespace-nowrap">
                {item.value}
              </span>
            </li>
          </Reveal>
        ))}
      </ul>

      {/* TODO: VERIFY WITH SCOTT — confirm total $ figure before launch */}
      <Reveal client:visible>
        <div class="mt-8 p-6 lg:p-8 rounded-xl bg-brand-charcoal text-white text-center">
          <p class="text-sm uppercase tracking-wider opacity-70 mb-2">Total package value</p>
          <p class="font-display text-4xl lg:text-5xl font-bold mb-2">$2,550+</p>
          <p class="text-base opacity-90">Your price: competitive market rate. Your estimate: free.</p>
          <a
            href="#rcs-fe-form"
            class="btn-primary mt-6 !bg-white !text-brand-primary hover:!bg-brand-cream"
          >
            Get My Free Estimate — Lock In These Inclusions →
          </a>
        </div>
      </Reveal>
    </div>
  </section>

  {/* ============================ TRIPLE PROMISE ============================ */}
  {/* TODO: VERIFY WITH SCOTT — these are public commitments. Approve wording before launch. */}
  <section class="bg-brand-charcoal text-white">
    <div class="container-x section">
      <Reveal client:visible>
        <div class="text-center mb-12 max-w-2xl mx-auto">
          <p class="kicker !text-brand-primary mb-3">The RCS Triple Promise</p>
          <h2 class="text-white text-fluid-3xl">Three commitments. In writing. On every job.</h2>
        </div>
      </Reveal>
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        {[
          {
            title: 'Same-Week Scheduling',
            body: "If we can't get you on the schedule within 7 days of your accepted estimate, your install is $200 off. Period.",
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><path d="M9 16l2 2 4-4" />
              </svg>
            ),
          },
          {
            title: 'Lifetime Craftsmanship',
            body: 'If our work fails for as long as you own the home, we come back and fix it. Free. No "warranty service fee" tricks.',
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            ),
          },
          {
            title: 'No-Surprise Pricing',
            body: 'Your estimate is the price you pay. No "we found rot, that\'ll be another $800" on install day. We inspect first, quote real, install on budget.',
            icon: (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
            ),
          },
        ].map((p, i) => (
          <Reveal client:visible delay={i * 0.1}>
            <div class="p-6 lg:p-7 bg-white/5 border border-white/10 rounded-xl h-full">
              <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center mb-4">
                {p.icon}
              </div>
              <h3 class="text-white text-xl mb-3">{p.title}</h3>
              <p class="text-white/75 leading-relaxed text-sm">{p.body}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* ============================ WHY RCS — 4 differentiators ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <p class="kicker mb-3">Why homeowners pick RCS</p>
        <h2>Built for Central Virginia weather, not for the lowest bid.</h2>
      </div>
    </Reveal>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        {
          big: '.032',
          title: 'Heavy-gauge aluminum',
          body: 'We use .032 aluminum. Most installers cut cost with .027 — thinner metal, faster failure.',
        },
        {
          big: null,
          icon: (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 9h18M3 15h18M9 3v18M15 3v18" />
            </svg>
          ),
          title: 'Hidden hangers',
          body: 'Rated 150+ lbs. Most crews still use spike-and-ferrule that tears free in heavy storms.',
        },
        {
          big: null,
          icon: (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 21l3-9 6-6 9 9-6 6-9 3z" />
              <path d="M14 7l3 3" />
            </svg>
          ),
          title: 'Fascia repair included',
          body: "Find rot on install day? We fix it in-line — no waiting, no surprise change orders.",
        },
        {
          big: null,
          icon: (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" /><path d="M9 12l2 2 4-4" />
            </svg>
          ),
          title: 'Lifetime warranty',
          body: 'Our craftsmanship is guaranteed for as long as you own the home. Most warranty for one year.',
        },
      ].map((card, i) => (
        <Reveal client:visible delay={i * 0.08}>
          <div class="text-center h-full">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-brand-primary text-white mb-4">
              {card.big ? <span class="font-display font-bold text-base">{card.big}</span> : card.icon}
            </div>
            <h3 class="text-lg mb-2">{card.title}</h3>
            <p class="text-sm text-ink-muted leading-relaxed">{card.body}</p>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  {/* ============================ REAL HOMES GALLERY ============================ */}
  <section class="bg-brand-cream">
    <div class="container-x section">
      <Reveal client:visible>
        <div class="text-center mb-10 max-w-2xl mx-auto">
          <p class="kicker mb-3">Real Scott. Real Crew. Real Homes.</p>
          <h2>Every install we've done — photographed, never staged.</h2>
        </div>
      </Reveal>

      {/* TODO: VERIFY WITH SCOTT — swap placeholder cells for real install photos. Each cell is one filename change. */}
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4 max-w-5xl mx-auto">
        {[
          { city: 'Charlottesville', span: 'lg:col-span-2 lg:row-span-2 aspect-square', tone: 'bg-brand-charcoal' },
          { city: 'Crozet', span: 'aspect-[4/3]', tone: 'bg-brand-primary' },
          { city: 'Lake Monticello', span: 'aspect-[4/3]', tone: 'bg-brand-charcoal/90' },
          { city: 'Albemarle', span: 'aspect-[4/3]', tone: 'bg-brand-primary/85' },
          { city: 'Greene', span: 'aspect-[4/3]', tone: 'bg-brand-charcoal' },
          { city: 'Madison', span: 'aspect-[4/3]', tone: 'bg-brand-primary/70' },
          { city: 'Barboursville', span: 'aspect-[4/3]', tone: 'bg-brand-charcoal/80' },
          { city: 'Fluvanna', span: 'aspect-[4/3]', tone: 'bg-brand-primary/90' },
        ].map((cell, i) => (
          <Reveal client:visible delay={i * 0.04}>
            <div class={`group relative rounded-lg overflow-hidden ${cell.span} ${cell.tone} text-white flex items-end p-4 cursor-pointer transition-all hover:shadow-2xl`}>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <span class="relative font-display font-semibold text-sm tracking-tight">
                <span class="block opacity-70 text-[10px] uppercase tracking-wider">RCS install</span>
                {cell.city}
              </span>
            </div>
          </Reveal>
        ))}
      </div>

      <Reveal client:visible>
        <p class="text-center mt-10 text-base lg:text-lg text-ink-muted">
          <strong class="text-ink-primary"><AnimatedCounter to={1247} client:visible /> homes</strong>
          <span class="mx-2">·</span>
          <strong class="text-ink-primary"><AnimatedCounter to={87} client:visible /> five-star reviews</strong>
          <span class="mx-2">·</span>
          <strong class="text-ink-primary">0 lawsuits</strong>
          <span class="mx-2">·</span>
          Family-run since 2014.
        </p>
      </Reveal>
    </div>
  </section>

  {/* ============================ TESTIMONIALS ============================ */}
  <section class="container-x section">
    <Reveal client:visible>
      <div class="max-w-3xl mx-auto text-center mb-12">
        <div class="text-amber-500 mb-3" aria-hidden="true">
          <span class="text-3xl tracking-widest">★★★★★</span>
        </div>
        <blockquote class="text-fluid-2xl text-ink-primary font-display leading-snug mb-6">
          “Scott showed up on time, walked the whole house with me, didn't try to upsell anything we didn't need. The crew was professional and the gutters are perfect after a year. Worth every dollar.”
        </blockquote>
        <div class="flex items-center justify-center gap-3">
          <div class="w-12 h-12 rounded-full bg-brand-cream border border-line flex items-center justify-center text-brand-primary font-display font-bold">MR</div>
          <div class="text-left">
            <p class="font-bold text-sm">Mike R.</p>
            <p class="text-xs text-ink-muted">Crozet, VA · Google Reviews</p>
          </div>
        </div>
      </div>
    </Reveal>

    {/* TODO: VERIFY WITH SCOTT — replace these short quotes with real Google Review pulls */}
    <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {[
        { initials: 'SK', quote: '"Quoted exactly what they installed. No surprise upcharges. Crew was in and out in a day."', name: 'Sandra K.', city: 'Albemarle' },
        { initials: 'TH', quote: '"Found rot under the old gutters and just fixed it — no weird change order conversation."', name: 'Tom H.', city: 'Lake Monticello' },
        { initials: 'LP', quote: '"Three years in, gutters still look brand new. Heavy storms have hit them and they don\'t move."', name: 'Linda P.', city: 'Crozet' },
      ].map((t, i) => (
        <Reveal client:visible delay={i * 0.1}>
          <div class="card p-6 bg-white h-full">
            <div class="text-amber-500 text-sm mb-3" aria-hidden="true">★★★★★</div>
            <blockquote class="text-sm text-ink-primary leading-relaxed mb-4">{t.quote}</blockquote>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-brand-cream border border-line flex items-center justify-center text-brand-primary text-xs font-bold">{t.initials}</div>
              <div>
                <p class="font-bold text-xs">{t.name}</p>
                <p class="text-[11px] text-ink-muted">{t.city}, VA</p>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  {/* ============================ MEET SCOTT ============================ */}
  <section class="bg-brand-cream">
    <div class="container-x section">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center max-w-5xl mx-auto">
        {/* TODO: VERIFY WITH SCOTT — swap placeholder for real Scott photo */}
        <Reveal client:visible variant="up" className="lg:col-span-5">
          <div class="aspect-[4/5] rounded-xl bg-gradient-to-br from-brand-charcoal to-brand-primary/30 text-white flex items-center justify-center text-center p-6 font-display">
            <span class="opacity-80 text-sm">[ Photo of Scott — Justin to swap ]</span>
          </div>
        </Reveal>
        <Reveal client:visible delay={0.1} className="lg:col-span-7">
          <p class="kicker mb-3">Meet Scott</p>
          <h2 class="mb-5">Scott Smith — RCS owner, on every estimate personally.</h2>
          {/* TODO: VERIFY WITH SCOTT — confirm bio facts (1,200+ installs, 0 lawsuits, Barboursville). */}
          <div class="space-y-4 text-base lg:text-lg text-ink-primary leading-relaxed max-w-prose">
            <p>
              I started Right Choice Seamless Gutters in 2014 after spending years watching cheap-gutter installs fail across Charlottesville. Spike hangers pulling out in the first heavy storm. Thin .027 aluminum buckling the second a tree limb landed on it. Crews that disappeared the moment a customer needed a warranty call returned.
            </p>
            <p>
              I refuse to send "estimators." When you book RCS, I'm the one in your driveway. I measure your house, I look at your fascia, I tell you exactly what it'll cost — and I write the number down. Twelve years and over 1,200 installs later, we've never had a lawsuit. That's not luck. That's how we work.
            </p>
            <p class="font-display font-semibold text-ink-primary">
              When you book RCS, you get me. That's the difference.
            </p>
          </div>
          <p class="mt-5 text-sm text-ink-muted italic">— Scott Smith, Owner · Barboursville, VA</p>
        </Reveal>
      </div>
    </div>
  </section>

