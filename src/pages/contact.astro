---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="Contact Right Choice Seamless Gutters | Barboursville VA"
  description="Phone, email, address, and hours for Right Choice Seamless Gutters in Barboursville, Virginia. Serving 8 Central VA counties."
>
  <section class="container-x section-tight">
    <p class="text-brand-accent text-xs font-bold uppercase tracking-[0.18em] mb-2">Contact</p>
    <h1 class="mb-4">Get in touch</h1>
    <p class="text-fluid-lg text-ink-muted max-w-3xl">
      Phone is the fastest way to reach us. For non-urgent quote requests, the form on our <a href="/quote/" class="text-brand-primary underline">quote page</a> is the most efficient — it gives us everything we need to schedule a walk-through.
    </p>
  </section>

  <section class="container-x section grid md:grid-cols-2 gap-8">
    <div class="card p-7 bg-white">
      <div class="text-xs font-bold uppercase text-brand-accent tracking-[0.18em] mb-3">Phone</div>
      <a href={`tel:${siteConfig.phoneRaw}`} class="text-3xl font-display font-bold text-brand-primary block mb-4">
        {siteConfig.phoneDisplay}
      </a>
      <div class="text-sm text-ink-muted space-y-1">
        <div>Monday–Friday: {siteConfig.hours.weekdays}</div>
        <div>Saturday: {siteConfig.hours.saturday}</div>
        <div>Sunday: {siteConfig.hours.sunday}</div>
      </div>
      <p class="text-xs text-ink-subtle mt-4">
        Voicemail off-hours. We return calls the next business day.
      </p>
    </div>

    <div class="card p-7 bg-white">
      <div class="text-xs font-bold uppercase text-brand-accent tracking-[0.18em] mb-3">Shop address</div>
      <p class="text-base">
        {siteConfig.address.street}<br />
        {siteConfig.address.city}, {siteConfig.address.state} {siteConfig.address.zip}
      </p>
      <p class="text-sm text-ink-muted mt-3">
        Our shop and equipment yard. We don't take walk-in customers — we come to your property to estimate.
      </p>
    </div>

    <div class="card p-7 bg-white">
      <div class="text-xs font-bold uppercase text-brand-accent tracking-[0.18em] mb-3">Email</div>
      <a href={`mailto:${siteConfig.email}`} class="text-brand-primary font-semibold break-all">
        {siteConfig.email}
      </a>
      <p class="text-sm text-ink-muted mt-3">
        Best for non-urgent inquiries, photos of existing gutter problems, or sending us additional details after a phone call.
      </p>
    </div>

    <div class="card p-7 bg-brand-cream">
      <div class="text-xs font-bold uppercase text-brand-accent tracking-[0.18em] mb-3">Service area</div>
      <p class="text-sm text-ink-muted mb-3">
        We serve all of Central Virginia within roughly 60 minutes of our shop:
      </p>
      <ul class="text-sm space-y-1 text-ink-muted">
        <li><a class="hover:underline" href="/locations/charlottesville/">Charlottesville</a> · <a class="hover:underline" href="/locations/albemarle/">Albemarle County</a></li>
        <li><a class="hover:underline" href="/locations/barboursville/">Barboursville</a> · <a class="hover:underline" href="/locations/orange/">Orange County</a></li>
        <li><a class="hover:underline" href="/locations/madison/">Madison County</a> · <a class="hover:underline" href="/locations/greene/">Greene County</a></li>
        <li><a class="hover:underline" href="/locations/fluvanna/">Fluvanna County</a> · <a class="hover:underline" href="/locations/louisa/">Louisa County</a></li>
      </ul>
    </div>
  </section>

  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto">
      <h2 class="text-white">Ready to schedule a walk-through?</h2>
      <p class="text-white/95 mt-3 mb-6">
        Free quote, on site, in person.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/quote/" class="btn-accent">Request a Quote</a>
        <a href={`tel:${siteConfig.phoneRaw}`} class="btn-secondary !text-white !border-white hover:!bg-white hover:!text-brand-primary">
          Call {siteConfig.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
