---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="Request a Free Quote | Right Choice Seamless Gutters"
  description="Free, no-pressure gutter estimate across Charlottesville and Central Virginia. We come to your home, walk the property, and provide a written quote."
>
  <section class="container-x section-tight">
    <p class="kicker mb-2">Free Quote</p>
    <h1 class="mb-4">Tell us about the project.</h1>
    <span class="hero-underline !mt-0 mb-6"></span>
    <p class="text-fluid-lg text-ink-muted max-w-3xl leading-relaxed">
      We'll come walk your property, measure, and give you a written quote on site or within 24 hours. No high-pressure sales, no "today only" pricing.
    </p>
  </section>

  <section class="container-x section">
    <div class="grid lg:grid-cols-3 gap-10">
      <form
        id="rcs-quote-form"
        class="lg:col-span-2 card p-7 space-y-5 bg-white"
        action="/api/quote"
        method="POST"
        novalidate
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="block text-sm font-semibold mb-1">Your name *</span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
            />
          </label>
          <label class="block">
            <span class="block text-sm font-semibold mb-1">Phone *</span>
            <input
              type="tel"
              name="phone"
              required
              autocomplete="tel"
              class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
            />
          </label>
        </div>

        <label class="block">
          <span class="block text-sm font-semibold mb-1">Email *</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
          />
        </label>

        <label class="block">
          <span class="block text-sm font-semibold mb-1">Property address *</span>
          <input
            type="text"
            name="address"
            required
            placeholder="Street"
            autocomplete="street-address"
            class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
          />
        </label>

        <div class="grid sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="block text-sm font-semibold mb-1">City</span>
            <input
              type="text"
              name="city"
              autocomplete="address-level2"
              class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
            />
          </label>
          <label class="block">
            <span class="block text-sm font-semibold mb-1">ZIP</span>
            <input
              type="text"
              name="postalCode"
              inputmode="numeric"
              autocomplete="postal-code"
              maxlength="10"
              class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
            />
          </label>
        </div>

        <fieldset>
          <legend class="block text-sm font-semibold mb-2">What do you need? (check all that apply)</legend>
          <div class="grid sm:grid-cols-2 gap-2 text-sm">
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="install" /> Seamless gutter installation</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="guards" /> Gutter guards</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="cleaning" /> Gutter cleaning</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="repair" /> Gutter repair</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="halfround" /> Half-round / copper</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="commercial" /> Commercial</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="fascia" /> Fascia / soffit</label>
            <label class="flex items-center gap-2"><input type="checkbox" name="services" value="drainage" /> Drainage / underground</label>
          </div>
        </fieldset>

        <label class="block">
          <span class="block text-sm font-semibold mb-1">Tell us about the project</span>
          <textarea
            name="message"
            rows="5"
            placeholder="What's prompting the call? Any photos you can describe? Timeline?"
            class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
          ></textarea>
        </label>

        <label class="block text-sm">
          <span class="block font-semibold mb-1">How did you hear about us? (optional)</span>
          <input
            type="text"
            name="source"
            class="w-full rounded border border-line px-3 py-2.5 focus:outline-none focus:border-brand-primary"
          />
        </label>

        <div class="pt-3">
          <button type="submit" id="rcs-quote-submit" class="btn-primary w-full sm:w-auto" data-default-label="Send Quote Request">
            Send Quote Request
          </button>
          <p class="text-xs text-ink-subtle mt-3">
            We'll call or text you within one business day to schedule the on-site walk-through. We do not sell or share your information.
          </p>
        </div>

        <!-- Inline state regions. Hidden by default; the script toggles them. -->
        <div
          id="rcs-quote-success"
          class="hidden rounded-lg border-2 border-accent-success/30 bg-accent-success/10 p-5 text-sm text-brand-charcoal"
          role="status"
          aria-live="polite"
        >
          <p class="font-semibold text-base mb-1">Got it. Scott will be in touch within one business day.</p>
          <p class="text-ink-muted">If your project is urgent or you'd rather talk now, call us at <a href={`tel:${siteConfig.phoneRaw}`} class="text-brand-primary font-semibold underline-offset-4 hover:underline">{siteConfig.phoneDisplay}</a>. Mon–Fri 9–5, Sat 9–12.</p>
        </div>

        <div
          id="rcs-quote-error"
          class="hidden rounded-lg border-2 border-brand-primary/30 bg-brand-light p-5 text-sm text-brand-charcoal"
          role="alert"
          aria-live="assertive"
        >
          <p class="font-semibold text-base mb-1">Submission didn't go through.</p>
          <p class="text-ink-muted mb-3">Network or server hiccup on our end. The fastest fix is to call us directly — we answer through Saturday at noon.</p>
          <a href={`tel:${siteConfig.phoneRaw}`} class="btn-primary !text-sm">Call {siteConfig.phoneDisplay}</a>
        </div>
      </form>

      <aside class="space-y-5">
        <div class="card p-6 bg-white">
          <h3 class="font-bold mb-2">Or call us directly</h3>
          <a href={`tel:${siteConfig.phoneRaw}`} data-call-location="quote_page" class="text-brand-primary font-bold text-xl block">
            {siteConfig.phoneDisplay}
          </a>
          <p class="text-sm text-ink-muted mt-2">
            Mon-Fri 9-5, Sat 9-12. Voicemail off-hours; we return calls the next business day.
          </p>
        </div>
        <div class="card p-6 bg-brand-cream">
          <h3 class="font-bold mb-2">Where we serve</h3>
          <ul class="text-sm space-y-1 text-ink-muted">
            <li>· Charlottesville and Albemarle County</li>
            <li>· Barboursville and Orange County</li>
            <li>· Culpeper</li>
            <li>· Madison County</li>
            <li>· Greene County</li>
            <li>· Fluvanna County (incl. Lake Monticello)</li>
            <li>· Louisa County (incl. Lake Anna)</li>
          </ul>
        </div>
        <div class="card p-6 bg-white">
          <h3 class="font-bold mb-2">What happens next</h3>
          <ol class="text-sm text-ink-muted space-y-2 list-decimal list-inside">
            <li>We respond by phone or text within one business day.</li>
            <li>We schedule a free on-site walk-through (usually within a week).</li>
            <li>You get a written quote on site or within 24 hours.</li>
            <li>You decide. The quote holds for 30+ days. No pressure.</li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Submit /api/quote via fetch, swap to inline success/error state.
  // Bind once per page, re-bind on Astro view-transition swaps.
  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  function rcsQuoteFormInit() {
    var form = document.getElementById('rcs-quote-form');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = 'true';
    // Stamp form-load time for the server-side too-fast bot check.
    form.dataset.loadedAt = String(Date.now());

    var btn = document.getElementById('rcs-quote-submit');
    var successEl = document.getElementById('rcs-quote-success');
    var errorEl = document.getElementById('rcs-quote-error');
    var errorBodyEl = errorEl ? errorEl.querySelector('p:nth-of-type(2)') : null;
    var defaultLabel = btn ? (btn.getAttribute('data-default-label') || btn.textContent) : 'Send Quote Request';

    // Field-level error rendering. Looks up the input by `name`, walks up to
    // its enclosing label/wrapper, drops a small red message under it, and
    // marks the input red. Cleared when the user starts editing.
    function clearAllFieldErrors() {
      form.querySelectorAll('.field-error').forEach(function (n) { n.remove(); });
      form.querySelectorAll('[data-field-errored]').forEach(function (input) {
        input.classList.remove('border-red-500');
        input.removeAttribute('data-field-errored');
        input.removeAttribute('aria-invalid');
      });
    }

    function setFieldError(fieldName, msg) {
      var input = form.querySelector('[name="' + fieldName + '"]');
      if (!input) return;
      var wrap = input.closest('label') || input.parentElement;
      if (!wrap) return;
      var existing = wrap.querySelector('.field-error');
      if (existing) existing.remove();
      var el = document.createElement('div');
      el.className = 'field-error text-sm text-red-600 mt-1';
      el.setAttribute('role', 'alert');
      el.textContent = msg;
      wrap.appendChild(el);
      input.classList.add('border-red-500');
      input.setAttribute('data-field-errored', 'true');
      input.setAttribute('aria-invalid', 'true');
    }

    // Wire onInput on every input so its field error clears as soon as the
    // user starts fixing it. One handler bound once.
    form.addEventListener('input', function (e) {
      var input = e.target;
      if (!input || !input.name) return;
      if (input.getAttribute('data-field-errored')) {
        var wrap = input.closest('label') || input.parentElement;
        if (wrap) {
          var existing = wrap.querySelector('.field-error');
          if (existing) existing.remove();
        }
        input.classList.remove('border-red-500');
        input.removeAttribute('data-field-errored');
        input.removeAttribute('aria-invalid');
      }
    });

    function setState(state) {
      if (!btn) return;
      if (state === 'pending') {
        btn.disabled = true;
        btn.setAttribute('aria-busy', 'true');
        btn.textContent = 'Sending…';
        if (successEl) successEl.classList.add('hidden');
        if (errorEl) errorEl.classList.add('hidden');
      } else if (state === 'success') {
        btn.disabled = false;
        btn.removeAttribute('aria-busy');
        btn.textContent = defaultLabel;
        if (successEl) successEl.classList.remove('hidden');
        if (errorEl) errorEl.classList.add('hidden');
        (window.dataLayer = window.dataLayer || []).push({
          event: 'quote_form_submit',
          page_path: window.location.pathname,
        });
      } else if (state === 'error') {
        btn.disabled = false;
        btn.removeAttribute('aria-busy');
        btn.textContent = defaultLabel;
        if (errorEl) errorEl.classList.remove('hidden');
        if (successEl) successEl.classList.add('hidden');
      }
    }

    function showErrorBanner(msg) {
      if (errorBodyEl && msg) errorBodyEl.textContent = msg;
      setState('error');
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      clearAllFieldErrors();

      // Client-side validation pass — same rules as the server. Catches the
      // common bad-email case before the API round-trip and gives the user a
      // field-level message.
      var clientErrs = {};
      var nameVal = ((form.elements['name'] && form.elements['name'].value) || '').trim();
      var phoneVal = ((form.elements['phone'] && form.elements['phone'].value) || '').trim();
      var emailVal = ((form.elements['email'] && form.elements['email'].value) || '').trim();
      var addressVal = ((form.elements['address'] && form.elements['address'].value) || '').trim();
      if (!nameVal) clientErrs.name = 'Name is required';
      if (!phoneVal) clientErrs.phone = 'Phone is required';
      else if (phoneVal.replace(/\D/g, '').length < 10) clientErrs.phone = 'Please enter a 10-digit phone number';
      if (!emailVal) clientErrs.email = 'Email is required';
      else if (!EMAIL_RE.test(emailVal)) clientErrs.email = 'Please enter a valid email address';
      if (!addressVal) clientErrs.address = 'Property address is required';
      if (Object.keys(clientErrs).length) {
        Object.keys(clientErrs).forEach(function (k) { setFieldError(k, clientErrs[k]); });
        var firstBadInput = form.querySelector('[data-field-errored]');
        if (firstBadInput) firstBadInput.focus();
        return;
      }

      setState('pending');
      try {
        var fd = new FormData(form);
        var payload = {};
        var services = [];
        fd.forEach(function (v, k) {
          if (k === 'services') services.push(String(v));
          else payload[k] = String(v);
        });
        if (services.length) payload.services = services;
        payload._t = Number(form.dataset.loadedAt) || Date.now();
        var apiUrl = window.location.origin + '/api/quote';
        var res = await fetch(apiUrl, {
          method: 'POST',
          body: JSON.stringify(payload),
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
        });
        var data = null;
        try { data = await res.json(); } catch (_) { /* non-JSON response */ }
        if (res.ok && data && data.ok) {
          setState('success');
          form.reset();
          if (successEl) successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        // Server-side validation: surface per-field errors instead of the
        // generic "Submission didn't go through" banner.
        if (data && data.error === 'validation_failed' && data.fields) {
          Object.keys(data.fields).forEach(function (k) { setFieldError(k, String(data.fields[k])); });
          var firstBad = form.querySelector('[data-field-errored]');
          if (firstBad) firstBad.focus();
          // Reset button state without showing the big red error card.
          if (btn) {
            btn.disabled = false;
            btn.removeAttribute('aria-busy');
            btn.textContent = defaultLabel;
          }
          return;
        }

        // GHL itself rejected a field. Show the detail in the banner.
        if (data && data.error === 'ghl_validation' && data.detail) {
          showErrorBanner('One of the fields needs another look: ' + data.detail);
          return;
        }

        console.error('[quote] non-OK response', res.status, data);
        showErrorBanner('Couldn’t submit just now. The fastest path is to call us directly.');
      } catch (err) {
        console.error('[quote] fetch error', err);
        setState('error');
      }
    });
  }
  document.addEventListener('astro:page-load', rcsQuoteFormInit);
</script>
