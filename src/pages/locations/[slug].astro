---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/schemas/FAQSchema.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((loc) => ({ params: { slug: loc.data.slug }, props: { loc } }));
}

const { loc } = Astro.props;
const { Content } = await loc.render();
const data = loc.data;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Service Area', item: `${siteConfig.url}/locations/` },
    { '@type': 'ListItem', position: 3, name: data.city, item: `${siteConfig.url}/locations/${data.slug}/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Gutter Installation, Cleaning, and Gutter Guards',
  provider: { '@id': `${siteConfig.url}/#business` },
  areaServed: {
    '@type': 'City',
    name: data.city,
    address: { '@type': 'PostalAddress', addressRegion: 'VA', addressLocality: data.city },
  },
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.city}, VA Gutter Services | RCS Gutters`}
  description={data.seoDescription ?? `Seamless gutters, gutter guards, and cleaning in ${data.city}, ${data.county}. Family-owned local crew.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <FAQSchema faqs={data.localFaqs} />
  </Fragment>

  <!-- Breadcrumbs -->
  <nav class="container-x pt-6 text-sm text-ink-muted" aria-label="Breadcrumb">
    <ol class="flex flex-wrap gap-1">
      <li><a href="/" class="hover:underline">Home</a></li>
      <li>›</li>
      <li><a href="/locations/" class="hover:underline">Service Area</a></li>
      <li>›</li>
      <li class="text-ink-primary font-medium">{data.city}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="container-x section-tight">
    <p class="text-brand-accent text-xs font-bold uppercase tracking-[0.18em] mb-2">
      {data.county} County, Virginia
    </p>
    <h1 class="mb-4">Gutter installation, cleaning, and Leaf Solution guards in {data.city}</h1>
    <p class="text-fluid-lg text-ink-muted max-w-3xl">{data.populationContext}</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={`/quote/?city=${encodeURIComponent(data.city)}`} class="btn-primary">
        Get a Free Quote in {data.city}
      </a>
      <a href={`tel:${siteConfig.phoneRaw}`} class="btn-secondary">
        Call {siteConfig.phoneDisplay}
      </a>
    </div>
  </section>

  <!-- Local context -->
  <section class="bg-brand-light section">
    <div class="container-x grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 prose-rcs">
        <Content />
      </div>
      <aside class="space-y-5">
        <div class="card p-5">
          <div class="text-xs font-bold uppercase text-ink-subtle tracking-wider mb-2">Climate</div>
          <p class="text-sm text-ink-muted">{data.climateNotes}</p>
        </div>
        {data.neighborhoods.length > 0 && (
          <div class="card p-5">
            <div class="text-xs font-bold uppercase text-ink-subtle tracking-wider mb-2">Neighborhoods we serve</div>
            <ul class="text-sm space-y-1 text-ink-muted">
              {data.neighborhoods.map((n) => <li>{n}</li>)}
            </ul>
          </div>
        )}
        {data.treeSpecies.length > 0 && (
          <div class="card p-5">
            <div class="text-xs font-bold uppercase text-ink-subtle tracking-wider mb-2">Local tree species we plan around</div>
            <ul class="text-sm space-y-1 text-ink-muted">
              {data.treeSpecies.map((t) => <li>{t}</li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <!-- Common problems -->
  {data.commonProblems.length > 0 && (
    <section class="section container-x">
      <h2 class="mb-2">Most common gutter problems we see in {data.city}</h2>
      <p class="text-ink-muted mb-8 max-w-2xl">
        Patterns we've noticed across hundreds of jobs in and around {data.city}.
      </p>
      <div class="grid md:grid-cols-2 gap-5">
        {data.commonProblems.map((p) => (
          <div class="card p-6">
            <div class="font-display font-bold text-lg mb-2">{p.problem}</div>
            <p class="text-sm text-ink-muted"><strong>Why:</strong> {p.cause}</p>
            <p class="text-sm text-ink-muted mt-2"><strong>What we recommend:</strong> {p.recommendation}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Local FAQs -->
  {data.localFaqs.length > 0 && (
    <section class="section bg-brand-light">
      <div class="container-x max-w-3xl">
        <h2 class="mb-6">{data.city} gutter FAQs</h2>
        <div class="space-y-3">
          {data.localFaqs.map((f) => (
            <details class="card p-5">
              <summary class="font-semibold cursor-pointer">{f.question}</summary>
              <p class="mt-3 text-ink-muted">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto">
      <h2 class="text-white">Local crew. Local response. Usually 5–7 days.</h2>
      <p class="text-white/80 mt-3 mb-6">
        Average response time to {data.city} from our Barboursville shop: about {data.responseTimeMinutes} minutes.
      </p>
      <a href={`/quote/?city=${encodeURIComponent(data.city)}`} class="btn-accent">
        Request a Quote in {data.city}
      </a>
    </div>
  </section>
</BaseLayout>
