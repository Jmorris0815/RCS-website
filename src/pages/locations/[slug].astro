---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQ from '../../components/FAQ.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((loc) => ({ params: { slug: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;
const { Content } = await loc.render();
const data = loc.data;

// All case studies in this city
const allStudies = await getCollection('caseStudies');
const localStudies = allStudies.filter(
  (cs) => cs.data.customerCity.toLowerCase() === data.city.toLowerCase()
);

// All other cities for cross-linking pill cloud
const otherCities = (await getCollection('locations'))
  .filter((l) => l.slug !== loc.slug)
  .sort((a, b) => a.data.city.localeCompare(b.data.city));

// Map bbox: ~0.18 degree padding around the city's lat/lng
const pad = 0.18;
const bbox = `${data.lng - pad}%2C${data.lat - pad}%2C${data.lng + pad}%2C${data.lat + pad}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Service Area', item: `${siteConfig.url}/locations/` },
    { '@type': 'ListItem', position: 3, name: data.city, item: `${siteConfig.url}/locations/${loc.slug}/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Gutter Installation, Cleaning, and Gutter Guards',
  provider: { '@id': `${siteConfig.url}/#business` },
  areaServed: {
    '@type': 'City',
    name: data.city,
    address: { '@type': 'PostalAddress', addressRegion: 'VA', addressLocality: data.city },
  },
};
---

<BaseLayout
  title={data.seoTitle ?? `${data.city}, VA Gutter Services | RCS Gutters`}
  description={data.seoDescription ?? `Seamless gutters, gutter guards, and cleaning in ${data.city}, ${data.county}. Family-owned local crew.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- Hero with decorative AI-slot background -->
  <section class="relative isolate overflow-hidden bg-brand-charcoal text-white">
    <div class="absolute inset-0 ai-slot opacity-90"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-brand-charcoal/95 via-brand-charcoal/70 to-brand-charcoal/40"></div>
    <span class="ai-slot-label !bottom-4 !right-4 !z-20">Decorative · TODO replace with {data.city} hero photo</span>

    <div class="relative container-x py-[clamp(72px,10vw,140px)]">
      <nav class="text-sm text-white/70 mb-6" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-1">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li>›</li>
          <li><a href="/locations/" class="hover:text-white">Service Area</a></li>
          <li>›</li>
          <li class="text-white font-medium">{data.city}</li>
        </ol>
      </nav>

      <p class="kicker !text-brand-gold-soft mb-3">{data.county} County · Virginia</p>
      <h1 class="text-white text-balance max-w-4xl">
        Gutter installation, cleaning &amp; Leaf Solution guards in {data.city}
      </h1>
      <span class="hero-underline mt-5"></span>
      <p class="text-white/90 text-fluid-lg max-w-3xl mt-7 leading-relaxed">{data.populationContext}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={`/quote/?city=${encodeURIComponent(data.city)}`} class="btn-primary">
          Get a Free Quote in {data.city}
        </a>
        <a href={`tel:${siteConfig.phoneRaw}`} class="btn-outline-white">
          Call {siteConfig.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- Pill clouds: neighborhoods + trees -->
  {(data.neighborhoods.length > 0 || data.treeSpecies.length > 0) && (
    <section class="bg-brand-cream border-b border-line">
      <div class="container-x py-10 grid md:grid-cols-2 gap-10 reveal">
        {data.neighborhoods.length > 0 && (
          <div>
            <p class="kicker mb-4">Neighborhoods we serve</p>
            <div class="flex flex-wrap gap-2">
              {data.neighborhoods.map((n) => (
                <span class="pill !cursor-default hover:!translate-y-0">{n}</span>
              ))}
            </div>
          </div>
        )}
        {data.treeSpecies.length > 0 && (
          <div>
            <p class="kicker mb-4">Local trees we plan around</p>
            <div class="flex flex-wrap gap-2">
              {data.treeSpecies.map((t) => (
                <span class="pill !cursor-default hover:!translate-y-0">{t}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Long-form local content -->
  <section class="section">
    <div class="container-x grid lg:grid-cols-12 gap-10">
      <article class="lg:col-span-8 prose-rcs reveal">
        <Content />
      </article>
      <aside class="lg:col-span-4 space-y-5 self-start lg:sticky lg:top-20">
        <div class="card p-6 bg-brand-cream">
          <p class="kicker-charcoal mb-3">Climate notes</p>
          <p class="text-sm text-ink-muted leading-relaxed">{data.climateNotes}</p>
        </div>
        <div class="card p-6">
          <p class="kicker-charcoal mb-3">Response time</p>
          <p class="text-sm leading-relaxed">
            Average drive from our Barboursville shop to most {data.city} addresses: <strong class="text-brand-primary">~{data.responseTimeMinutes} minutes</strong>. We typically book on-site estimates within 5-7 days of your call.
          </p>
        </div>
        <a href={`/quote/?city=${encodeURIComponent(data.city)}`} class="btn-primary w-full justify-center">
          Get a Quote in {data.city}
        </a>
      </aside>
    </div>
  </section>

  <!-- Common problems tile grid -->
  {data.commonProblems.length > 0 && (
    <section class="section bg-brand-cream">
      <div class="container-x">
        <div class="max-w-2xl mb-10 reveal">
          <span class="section-divider"></span>
          <p class="kicker mb-3">Local pattern</p>
          <h2 class="text-balance">Most common gutter problems we see in {data.city}</h2>
          <p class="text-ink-muted mt-4">Patterns we've noticed across hundreds of jobs in and around {data.city}.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {data.commonProblems.map((p) => (
            <article class="card p-7 reveal">
              <h3 class="font-display text-xl mb-3 text-balance">{p.problem}</h3>
              <p class="text-sm text-ink-muted mb-3">
                <span class="text-[11px] uppercase tracking-wider font-bold text-brand-primary">Why ·</span> {p.cause}
              </p>
              <p class="text-sm text-ink-muted">
                <span class="text-[11px] uppercase tracking-wider font-bold text-brand-primary">What we recommend ·</span> {p.recommendation}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related case studies -->
  {localStudies.length > 0 && (
    <section class="section">
      <div class="container-x">
        <div class="max-w-2xl mb-10 reveal">
          <span class="section-divider"></span>
          <p class="kicker mb-3">From our archive</p>
          <h2 class="text-balance">Recent work in {data.city}</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {localStudies.map((cs) => (
            <a href={`/case-studies/${cs.slug}/`} class="card p-7 group">
              <p class="kicker-charcoal mb-3">{cs.data.dateCompleted.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>
              <h3 class="font-display text-xl mb-3 group-hover:text-brand-primary transition-colors text-balance">{cs.data.title}</h3>
              <p class="text-sm text-ink-muted line-clamp-3">{cs.data.problem}</p>
              <span class="inline-flex items-center gap-2 mt-4 text-brand-primary font-semibold text-sm">
                Read the case study <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Map -->
  <section class="section bg-brand-cream">
    <div class="container-x">
      <div class="max-w-2xl mx-auto text-center mb-8 reveal">
        <span class="section-divider mx-auto"></span>
        <p class="kicker mb-3">Service map</p>
        <h2 class="text-balance">Where {data.city} sits in our service radius</h2>
      </div>
      <div class="rounded-2xl border-2 border-brand-primary/30 shadow-card overflow-hidden bg-white">
        <iframe
          title={`Map centered on ${data.city}, Virginia with RCS Gutters service radius`}
          loading="lazy"
          width="100%" height="380"
          style="border:0;display:block;"
          src={`https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${data.lat}%2C${data.lng}`}
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Local FAQs -->
  {data.localFaqs.length > 0 && (
    <FAQ faqs={data.localFaqs} kicker={`${data.city} questions`} heading={`${data.city} gutter FAQs`} />
  )}

  <!-- Other cities pill cloud -->
  <section class="bg-brand-charcoal text-white py-12">
    <div class="container-x text-center reveal">
      <p class="kicker !text-brand-gold-soft mb-4">Also serving</p>
      <div class="flex flex-wrap gap-2 justify-center">
        {otherCities.map((o) => (
          <a href={`/locations/${o.slug}/`} class="inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-white/5 text-white px-3 py-1.5 text-[13px] font-medium hover:bg-white hover:text-brand-charcoal transition-colors">
            {o.data.city}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-brand-primary text-white">
    <div class="container-x text-center max-w-2xl mx-auto reveal">
      <p class="kicker !text-brand-gold-soft mb-3">Ready when you are</p>
      <h2 class="font-display text-white text-balance mb-5">Local crew. Local accountability.</h2>
      <p class="text-white/95 text-fluid-lg mb-7 leading-relaxed">
        Free written estimate at your {data.city} home. Usually scheduled within a week.
      </p>
      <a href={`/quote/?city=${encodeURIComponent(data.city)}`} class="btn-accent">
        Request a Quote in {data.city}
      </a>
    </div>
  </section>
</BaseLayout>
