---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LocalBusinessSchema from '../components/schemas/LocalBusinessSchema.astro';
import FAQ from '../components/FAQ.astro';
import Lightbox from '../components/Lightbox.astro';
import PictureHero from '../components/PictureHero.astro';
import Picture from '../components/Picture.astro';
import DesignedBlock from '../components/DesignedBlock.astro';
import { siteConfig } from '../config/site';

const HERO_IMG = '/images/jobs/truck-jobsite-barn.jpg';

const services = (await getCollection('services'))
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99));

const cities = (await getCollection('locations'))
  .sort((a, b) => a.data.city.localeCompare(b.data.city))
  .map((l) => ({ slug: l.slug, name: l.data.city, county: l.data.county }));

const homeFaqs = [
  { question: 'How long does a typical gutter install take?',
    answer: 'Most single-family homes in our service area take a single day from start to finish. Usually 6 to 10 hours including teardown of the existing system, on-site extrusion, hanger placement, gutter hanging, downspouts, and cleanup. Larger homes (4,000+ sq ft) or multi-building properties can take two days.' },
  { question: 'Do you charge for estimates?',
    answer: 'No. Estimates are free, on-site, and we give you a written quote either the same day or within 24 hours. No "today only" pricing, no high-pressure sales. The quote holds for 30+ days.' },
  { question: "What's the difference between seamless and sectional gutters?",
    answer: 'Sectional gutters come in 10-foot pre-cut lengths assembled with caulked seams. Every seam is a future leak point. Seamless gutters are extruded on site to the exact length of your roof line, with seams only at the corners. The difference shows up about year five, when sectional seams start weeping and seamless systems are still tight.' },
  { question: 'Which gutter guard do you recommend?',
    answer: "It depends on your tree mix. Pine-heavy lots get Xtreme stainless micro-mesh; mixed deciduous gets Xtreme or Evelyn's depending on aesthetics; mostly-oak hardwood lots can usually run New Wave at lower cost. We walk every property and recommend the right product. Not the most expensive one." },
  { question: 'Do you still need to clean gutters that have guards?',
    answer: 'Less, but not never. Stainless micro-mesh dramatically reduces hand cleanouts but a once-a-year top-rinse keeps flow rates high. Especially on properties with pine sap or heavy pollen. We offer the annual rinse as a small add-on; it takes about an hour for a typical home.' },
  { question: 'Do you offer financing?',
    answer: "Yes. See our financing page. We work with two consumer-finance partners that handle home-improvement loans for projects in the $1,500 to $15,000 range. Approval is usually quick and most projects qualify for 12 to 60 month terms." },
  { question: 'Are you licensed and insured?',
    answer: "Yes, we are fully insured and operate as a Virginia-licensed contractor. License number is currently being updated; full credentials are available on request and will appear in the site footer once finalized." },
  { question: 'How do I know if my gutters need replacing vs just repair?',
    answer: 'Sagging mid-runs, pulled hangers, water sheeting over the front during storms, fascia rot behind the gutter, or visible separation at the corners usually mean replacement is the right call. If the gutters are .032 aluminum and structurally sound, repair is often cheaper. We tell you straight at the estimate which one your home needs.' },
];

// 6 service tile entries. 2 large (top row), 4 small (bottom row)
const tiles = [
  { slug: 'gutter-guards', title: 'Gutter Guards',
    blurb: 'Authorized Leaf Solution dealer. Stainless micro-mesh, punched aluminum, and capillary systems matched to your tree mix.',
    img: '/images/products/straight-miter-fall-background.jpg', large: true },
  { slug: 'seamless-gutter-installation', title: 'Seamless Installation',
    blurb: '.032 aluminum, hidden hangers, custom-extruded on site. The way new gutters should be done.',
    img: '/images/products/OUTSIIDE-CORNER-MITER-INSTALLED.jpg', large: true },
  { slug: 'gutter-cleaning', title: 'Gutter Cleaning',
    blurb: 'Twice-a-year service tuned to your tree zone. Hand cleaned, flushed, photo-documented.',
    img: '/images/jobs/clogged-leaves.jpg', large: false },
  { slug: 'half-round-gutters', title: 'Half-Round',
    blurb: 'Aluminum and copper half-round for historic homes and high-end new builds where K-style is wrong.',
    img: '/images/jobs/install-copper-federal-brick.jpg', large: false },
  { slug: 'commercial-gutters', title: 'Commercial',
    blurb: 'Box gutters, scuppers, and oversized K-style for retail, ag, and church properties.',
    img: '/images/jobs/truck-commercial-flatroof.jpg', large: false },
  { slug: 'fascia-and-soffit', title: 'Fascia & Soffit',
    blurb: 'Wrap, repair, or replace. The trim work that keeps water out of your walls.',
    img: '/images/jobs/rotted-roof-deck.jpg', large: false },
];

// Process steps
const steps = [
  { n: 1, title: 'Free on-site walk-through',
    body: "We come measure your property, walk every roof edge, count downspouts, and look at the fascia underneath. No pressure, no upsell. We want to understand the actual job before we price it.",
    img: '/images/jobs/clogged-leaves.jpg', alt: 'Inspecting a clogged gutter packed with autumn leaves',
    icon: 'clipboard' },
  { n: 2, title: 'Written quote within 24 hours',
    body: "You get a clear written quote either on the spot or by the next business day. Line items broken out. Gutter, downspouts, accessories, fascia repair. So you can see exactly what you're paying for. The price holds for 30+ days.",
    img: null, alt: '', icon: 'file-text',
    designedKind: 'cream', designedTitle: 'Written quote · 24 hours',
    designedSubtitle: 'On-site or by next business day',
    designedTexture: '/images/jobs/clogged-leaves.jpg' },
  { n: 3, title: 'Schedule (usually within a week)',
    body: "Most jobs in our service area get scheduled within 5 to 7 days of approval. We confirm by phone or text the day before, give you a tight arrival window, and show up with the truck and crew.",
    img: '/images/jobs/truck-jobsite-barn.jpg',
    alt: 'The RCS truck arrived at a Central Virginia job site, parked in front of a red-roof barn ready to start the install',
    icon: 'calendar' },
  { n: 4, title: 'Install in one day',
    body: "Most single-family homes are a single day's work. Teardown, on-site extrusion, hanger placement, gutter hanging, downspouts, and cleanup. We protect your landscaping, sweep the work zone, and haul off the old material.",
    img: '/images/products/OUTSIIDE-CORNER-MITER-INSTALLED.jpg', alt: 'Newly installed seamless gutter with corner miter on a Central Virginia home',
    icon: 'hammer' },
  { n: 5, title: 'Walk-through + photo report',
    body: "Before we leave we walk the job with you. Pull on hangers, check pitch, verify downspout discharge. You get a photo report by email so you have documentation of what we installed and how.",
    img: '/images/jobs/before-after-cleaning.jpg', alt: 'Before-and-after split: clogged gutter on the left, clean Leaf Solution guard on the right',
    icon: 'camera' },
];
---

<BaseLayout
  title="Right Choice Seamless Gutters | Central Virginia Gutter Installation & Leaf Solution Guards"
  description="Family-owned seamless gutter installer serving Charlottesville, Barboursville, and Central Virginia. Authorized Leaf Solution dealer. Free quotes, .032 aluminum standard, hidden hangers, real local crew."
  heroImage={HERO_IMG}
>
  <LocalBusinessSchema slot="head" />

  <!-- ═══════════════════ 1. HERO ═══════════════════ -->
  <section class="relative isolate overflow-hidden bg-brand-charcoal text-white">
    <PictureHero
      base="/images/jobs/truck-jobsite-barn"
      alt="The RCS Gutters branded box truck parked in front of a Central Virginia red-roof barn, full RCS wrap visible"
      class="absolute inset-0 w-full h-full object-cover object-center"
      width={1600} height={1136}
      loading="eager" fetchpriority="high"
    />
    <!-- Dark gradient overlay covering bottom 60% -->
    <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/95 via-brand-charcoal/55 to-brand-charcoal/10"></div>
    <!-- subtle vignette via radial -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 60% 30%, transparent 0%, rgba(0,0,0,0.25) 100%);"></div>

    <div class="relative container-x py-[clamp(120px,16vw,200px)] grid items-end min-h-[68svh]">
      <div class="max-w-3xl">
        <p class="kicker !text-brand-gold-soft mb-5">Central Virginia · Family-Owned Since 2014</p>
        <h1 class="font-display text-white text-balance text-[clamp(2.5rem,5.5vw,5rem)] leading-[1.02]">
          Central Virginia's Family-Owned Gutter Specialists Since 2014
        </h1>
        <span class="hero-underline"></span>
        <p class="text-fluid-lg text-white/85 max-w-2xl mt-6 mb-8 leading-relaxed">
          Seamless aluminum gutters, Leaf Solution gutter guards, and honest cleaning service across Charlottesville, Barboursville, and the surrounding counties.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/quote/" class="btn-primary !text-base">Get Your Free Quote</a>
          <a href="/services/seamless-gutter-installation/" class="btn-outline-white !text-base">See How We Install</a>
        </div>
      </div>
    </div>
  </section>

  <!-- One-line trust strip below hero -->
  <section class="bg-white border-b border-line">
    <div class="container-x py-4">
      <ul class="flex flex-wrap items-center justify-center md:justify-between gap-x-6 gap-y-2 text-[13px] font-medium text-brand-warm-gray text-center md:text-left">
        <li class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Family-owned since 2014
        </li>
        <li class="hidden md:block w-px h-4 bg-line" aria-hidden="true"></li>
        <li class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Authorized Leaf Solution dealer
        </li>
        <li class="hidden md:block w-px h-4 bg-line" aria-hidden="true"></li>
        <li class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Serving 8 Central VA counties
        </li>
        <li class="hidden md:block w-px h-4 bg-line" aria-hidden="true"></li>
        <li class="flex items-center gap-2">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Licensed &amp; insured
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════ 2. STATS STRIP ═══════════════════ -->
  <section class="bg-brand-cream">
    <div class="container-x py-14 grid grid-cols-2 md:grid-cols-5 gap-y-8 gap-x-4 text-center reveal">
      <div>
        <div class="font-display text-5xl md:text-6xl font-semibold text-brand-primary leading-none tabular-nums">
          <span data-count-to="12" data-count-dur="1400">0</span><span>+</span>
        </div>
        <div class="text-[13px] text-brand-warm-gray uppercase tracking-wider mt-2">Years on Central VA roofs</div>
      </div>
      <div>
        <div class="font-display text-5xl md:text-6xl font-semibold text-brand-primary leading-none tabular-nums">
          <span data-count-to="8" data-count-dur="1200">0</span>
        </div>
        <div class="text-[13px] text-brand-warm-gray uppercase tracking-wider mt-2">Counties served</div>
      </div>
      <div>
        <div class="font-display text-5xl md:text-6xl font-semibold text-brand-primary leading-none tabular-nums">
          <span data-count-to="24" data-count-dur="1400">0</span><span>h</span>
        </div>
        <div class="text-[13px] text-brand-warm-gray uppercase tracking-wider mt-2">Written quote turnaround</div>
      </div>
      <div>
        <div class="font-display text-5xl md:text-6xl font-semibold text-brand-primary leading-none">
          .032
        </div>
        <div class="text-[13px] text-brand-warm-gray uppercase tracking-wider mt-2">Aluminum gauge standard</div>
      </div>
      <div>
        <div class="font-display text-5xl md:text-6xl font-semibold text-brand-primary leading-none tabular-nums">
          <span data-count-to="100" data-count-dur="1400">0</span><span>%</span>
        </div>
        <div class="text-[13px] text-brand-warm-gray uppercase tracking-wider mt-2">Locally owned</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 3. HOW WE WORK ═══════════════════ -->
  <section class="section">
    <div class="container-x">
      <div class="max-w-2xl mx-auto text-center mb-14 reveal">
        <p class="kicker mb-3">Our process</p>
        <h2 class="text-balance">Five steps from your call to a finished roof line</h2>
        <p class="text-ink-muted mt-4 leading-relaxed">
          No mystery, no surprises. Here's exactly what working with us looks like. Start to finish.
        </p>
      </div>

      <ol class="space-y-16 lg:space-y-24">
        {steps.map((s, i) => (
          <li class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center reveal">
            <div class={`lg:col-span-6 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              {s.img ? (
                <Picture src={s.img} alt={s.alt}
                  class="w-full h-auto rounded-2xl shadow-card object-cover aspect-[4/3]"
                  loading="lazy" width={1200} height={900} />
              ) : (
                <DesignedBlock
                  kind={s.designedKind as any}
                  icon={s.icon as any}
                  title={s.designedTitle ?? s.title}
                  subtitle={s.designedSubtitle}
                  texture={s.designedTexture}
                  class="rounded-2xl shadow-card aspect-[4/3]"
                />
              )}
            </div>
            <div class={`lg:col-span-6 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="flex items-center gap-4 mb-5">
                <div class="font-display text-6xl text-brand-primary leading-none tabular-nums" aria-hidden="true">{String(s.n).padStart(2, '0')}</div>
                <span class="block w-16 h-px bg-brand-gold"></span>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-charcoal" aria-hidden="true">
                  {s.icon === 'clipboard' && <><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="m9 14 2 2 4-4"/></>}
                  {s.icon === 'file-text' && <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></>}
                  {s.icon === 'calendar' && <><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>}
                  {s.icon === 'hammer' && <><path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8v0l3 3h1.172a2 2 0 0 1 1.414.586L19.5 13.5"/></>}
                  {s.icon === 'camera' && <><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></>}
                </svg>
              </div>
              <h3 class="font-display mb-3 text-pretty">{s.title}</h3>
              <p class="text-ink-muted leading-relaxed">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ═══════════════════ 4. SERVICE TILES (asymmetric) ═══════════════════ -->
  <section class="section bg-brand-charcoal text-white">
    <div class="container-x">
      <div class="flex items-end justify-between mb-10 gap-6 reveal">
        <div>
          <p class="kicker !text-brand-gold-soft mb-3">Services</p>
          <h2 class="text-white text-balance">Every gutter service, one local crew</h2>
        </div>
        <a href="/services/" class="hidden md:inline-flex text-white/80 font-semibold hover:text-white transition-colors whitespace-nowrap">
          See all services →
        </a>
      </div>

      <!-- Top row: 2 large -->
      <div class="grid md:grid-cols-2 gap-4 md:gap-5 mb-4 md:mb-5">
        {tiles.filter(t => t.large).map((t) => (
          <a href={`/services/${t.slug}/`} class="group relative block overflow-hidden rounded-2xl aspect-[16/10] bg-brand-warm-gray ring-1 ring-white/10">
            {t.img && (
              <Picture src={t.img} alt="" loading="lazy" width={1200} height={750}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal via-brand-charcoal/45 to-transparent"></div>
            <div class="absolute inset-0 p-7 flex flex-col justify-end">
              <h3 class="text-white font-display text-2xl mb-2">{t.title}</h3>
              <p class="text-white/85 text-sm max-w-md leading-relaxed">{t.blurb}</p>
              <span class="mt-3 inline-flex items-center gap-2 text-brand-gold-soft text-sm font-semibold">
                Learn more <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Bottom row: 4 small -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
        {tiles.filter(t => !t.large).map((t) => (
          <a href={`/services/${t.slug}/`} class="group relative block overflow-hidden rounded-xl aspect-[4/5] bg-brand-warm-gray ring-1 ring-white/10">
            {t.img && (
              <Picture src={t.img} alt="" loading="lazy" width={600} height={750}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/95 via-brand-charcoal/40 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-4">
              <h3 class="text-white font-display text-lg mb-1">{t.title}</h3>
              <p class="text-white/75 text-xs leading-snug line-clamp-2">{t.blurb}</p>
            </div>
          </a>
        ))}
      </div>

      <a href="/services/" class="md:hidden mt-6 inline-flex text-white/80 font-semibold">See all services →</a>
    </div>
  </section>

  <!-- ═══════════════════ 5. FEATURED PRODUCT. Leaf Solution ═══════════════════ -->
  <section class="section bg-brand-cream">
    <div class="container-x grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-6 reveal">
        <span class="section-divider"></span>
        <p class="kicker mb-3">Featured product · Authorized dealer</p>
        <h2 class="text-balance mb-5">Why we install Leaf Solution</h2>
        <p class="text-ink-muted leading-relaxed mb-6">
          We chose Leaf Solution as our primary gutter-guard partner for three reasons. The factory is in Rochelle, VA, about thirty minutes from our shop, so warranty questions and special-order colors get a relationship instead of a 1-800 number. They only sell to authorized contractors, which keeps install quality consistent across the dealer network. And the products perform: across hundreds of installs in Central Virginia, the failures we end up tearing off are almost always cheaper non-Leaf Solution alternatives.
        </p>
        <ul class="space-y-3 mb-8">
          {[
            ['Stainless steel micro-mesh', 'Surgical-grade aperture sheds pine needles, sycamore bark, and oak debris'],
            ['Up to 60 GPM throughput', 'Handles the worst Central VA summer thunderstorms without sheeting'],
            ['25-year material warranty', 'Manufacturer-backed, transferable to next owner'],
            ['Three product tiers', 'Xtreme, New Wave, and Evelyn\'s Leaf Solution. Matched to your home'],
          ].map(([h, d]) => (
            <li class="flex gap-3">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary flex-shrink-0 mt-0.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <div>
                <div class="font-semibold text-brand-charcoal">{h}</div>
                <div class="text-sm text-ink-muted">{d}</div>
              </div>
            </li>
          ))}
        </ul>
        <div class="flex flex-wrap gap-3">
          <a href="/products/xtreme-gutter-guard/" class="btn-primary">Explore Xtreme</a>
          <a href="/configurator/" class="btn-secondary">Take the 4-question quiz</a>
        </div>
      </div>
      <div class="lg:col-span-6 reveal">
        <div class="relative">
          <Picture
            src="/images/products/straight-miter-fall-background.jpg"
            alt="Leaf Solution gutter guard installed on a Central Virginia shingle roof in fall"
            class="w-full h-auto rounded-2xl shadow-card object-cover aspect-[4/3]"
            loading="lazy" width={1400} height={1050}
          />
          <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-card p-4 flex items-center gap-3 max-w-[280px]">
            <img src="/images/products/xtreme-overhead-panel-line.png" alt="" class="h-12 w-auto" loading="lazy" width="100" height="64" />
            <div>
              <div class="text-[11px] uppercase tracking-wider text-brand-primary font-bold">Xtreme</div>
              <div class="text-xs text-ink-muted leading-snug">Stainless mesh · 25-yr warranty · most-installed across Central VA</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 6. RECENT WORK GALLERY (with lightbox) ═══════════════════ -->
  <section class="section">
    <div class="container-x">
      <div class="flex items-end justify-between mb-10 gap-6 reveal">
        <div>
          <span class="section-divider"></span>
          <p class="kicker mb-3">Recent work</p>
          <h2 class="text-balance">A taste of the work. The full gallery has more.</h2>
        </div>
        <a href="/gallery/" class="hidden md:inline-flex text-brand-primary font-semibold hover:text-brand-red-deep transition-colors whitespace-nowrap">
          See the full gallery →
        </a>
      </div>

      <!-- Masonry-feel: CSS columns. 6 strongest photos from the gallery -->
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 [column-fill:_balance]">
        {[
          { src: '/images/jobs/install-copper-federal-brick.jpg', alt: 'Federal-style red-brick three-story home with newly installed copper gutters and downspouts', cap: 'Copper install · Federal-style brick home' },
          { src: '/images/jobs/install-downspout-sage-clapboard.jpg', alt: 'Newly installed white K-style gutter and downspout running down a sage-green clapboard wall on a new-construction home', cap: 'New install · sage-clapboard new build' },
          { src: '/images/jobs/before-after-cleaning.jpg', alt: 'Before-and-after split: gutter packed with brown leaves vs. clean Leaf Solution micro-mesh after upgrade', cap: 'Before / after · cleaning + Leaf Solution upgrade' },
          { src: '/images/products/straight-miter-fall-background.jpg', alt: 'Leaf Solution straight-miter gutter guard installed on a shingle roof above a fall-leafed lawn', cap: 'Gutter guard install · pine debris zone' },
          { src: '/images/jobs/install-modern-board-batten.jpg', alt: 'Modern board-and-batten home with dark-bronze metal roof and new black gutters under construction', cap: 'New construction · board-and-batten home' },
          { src: '/images/jobs/install-copper-brick-home.jpg', alt: 'Brick colonial home with new copper gutters, dormer trim, and matching downspouts', cap: 'Copper install · brick colonial' },
        ].map((p) => {
          const base = p.src.replace(/\.(jpg|jpeg|png)$/i, '');
          return (
            <figure class="break-inside-avoid mb-4 group cursor-zoom-in"
              data-lightbox-src={p.src} data-lightbox-alt={p.alt}>
              <div class="relative overflow-hidden rounded-xl shadow-soft hover:shadow-lift transition-shadow">
                <picture>
                  <source srcset={`${base}.avif`} type="image/avif" />
                  <source srcset={`${base}.webp`} type="image/webp" />
                  <img src={p.src} alt={p.alt} loading="lazy" decoding="async"
                    class="w-full h-auto block transition-transform duration-500 group-hover:scale-105" />
                </picture>
                <figcaption class="photo-overlay-caption text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  {p.cap}
                </figcaption>
              </div>
            </figure>
          );
        })}
      </div>

      <div class="mt-8 flex items-center justify-center md:hidden">
