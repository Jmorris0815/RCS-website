    { "source": "/areas-we-serve/earlysville", "destination": "/locations/albemarle/", "permanent": true },
    { "source": "/areas-we-serve/free-union", "destination": "/locations/albemarle/", "permanent": true },
    { "source": "/areas-we-serve/hollymead", "destination": "/locations/albemarle/", "permanent": true },
    { "source": "/areas-we-serve/hood", "destination": "/locations/madison/", "permanent": true },
    { "source": "/areas-we-serve/pratts", "destination": "/locations/madison/", "permanent": true },
    { "source": "/areas-we-serve/quinque", "destination": "/locations/greene/", "permanent": true },
    { "source": "/areas-we-serve/rochelle", "destination": "/locations/madison/", "permanent": true },
    { "source": "/areas-we-serve/ruckersville", "destination": "/locations/greene/", "permanent": true },
    { "source": "/areas-we-serve/somerset", "destination": "/locations/orange/", "permanent": true },
