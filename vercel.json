    { "source": "/half-round-gutters", "destination": "/services/half-round-gutters/", "permanent": true },
    { "source": "/services/gutter-guards", "destination": "/services/gutter-guards/", "permanent": true },
    { "source": "/services/gutter-cleaning", "destination": "/services/gutter-cleaning/", "permanent": true },
